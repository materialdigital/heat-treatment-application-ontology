###  https://w3id.org/pmd/hto/HTO_0000019
:HTO_0000019 rdf:type owl:Class ;
             rdfs:subClassOf :HTO_0000040 ;
             owl:disjointWith :HTO_0000020 ;
             terms:source "DIN 17022-5:2000, §1" ,
                          "DIN 17022-5:2000, §4" ,
                          "DIN EN ISO 4885:2018, §3.200" ;
             rdfs:label "Oberflächenhärtung"@de ,
                        "surface hardening"@en ;
             skos:altLabel "Oberflächenhärtung"@de ,
                           "Randschichthärtung"@de ;
             skos:definition "Auf die Randschicht beschränkte Härtung (3.167)."@de ,
                             "Hardening (3.167) restricted to the surface layer."@en ,
                             "Hardening process where only the surface of a part and not its entire volume is hardened." ;
             skos:editorialNote "DIN audit fix (2026-06-09): DIN EN ISO 4885 §3.200 lemma is 'Randschichthärten'; DIN 17022-5 uses 'Randschichthärten' exclusively in its title. The hto-edit.owl DE label 'Oberflächenhärtung' is a DIN-10052 / legacy synonym (already retained in hto-edit.owl as skos:altLabel — preserved here). The DIN-canonical 'Randschichthärten' is hoisted to skos:prefLabel."@en .


###  https://w3id.org/pmd/hto/HTO_0000020
:HTO_0000020 rdf:type owl:Class ;
             rdfs:subClassOf :HTO_0000040 ;
             terms:source "DIN EN ISO 4885:2018, §3.209" ;
             rdfs:label "Durchhärten"@de ,
                        "through hardening"@en ;
             skos:definition "Härtung (3.167), bei der die Bildung von Martensit (3.137) bis zum Kern eines Werkstückes erreicht wird."@de ,
                             "Hardening (3.167), in which the formation of martensite (3.137) extends right to the core of a workpiece." .


###  https://w3id.org/pmd/hto/HTO_0000021
:HTO_0000021 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty obo:BFO_0000051 ;
                               owl:someValuesFrom :HTO_0000013
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty obo:BFO_0000051 ;
                               owl:someValuesFrom :HTO_0000023
                             ] ;
             terms:source "DIN 17022-1:1994, §3.3" ,
                          "DIN EN ISO 4885:2018, §3.169" ,
                          "DIN EN ISO 683-2:2018, Tab.11" ;
             rdfs:label "QT recipe"@en ;
             skos:definition "A heat treatment recipe outlining the steps and parameters for carrying out a quenching and tempering process."@en ,
                             "Wärmebehandlungsrezept, in dem die Schritte und Parameter zur Durchführung eines Vergütungsprozesses beschrieben werden."@de .


###  https://w3id.org/pmd/hto/HTO_0000022
:HTO_0000022 rdf:type owl:Class ;
             rdfs:subClassOf _:genid27 ,
                             [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                      owl:onProperty obo:BFO_0000117 ;
                                                      owl:someValuesFrom :HTO_0000038
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty obo:BFO_0000117 ;
                                                      owl:someValuesFrom :HTO_0000040
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty obo:BFO_0000117 ;
                                                      owl:someValuesFrom [ owl:intersectionOf ( :HTO_0000040
                                                                                                [ rdf:type owl:Restriction ;
                                                                                                  owl:onProperty obo:BFO_0000063 ;
                                                                                                  owl:someValuesFrom :HTO_0000038
                                                                                                ]
                                                                                              ) ;
                                                                           rdf:type owl:Class
                                                                         ]
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
             terms:source "DIN 17022-1:1994, §3.3" ,
                          "DIN EN ISO 4885:2018, §3.169" ,
                          "DIN EN ISO 683-2:2018, Tab.1 Zeile 5 (+QT)" ;
             rdfs:label "Vergüten"@de ,
                        "quenching and tempering"@en ;
             skos:altLabel "Abschrecken und Anlassen"@de ,
                           "QT"@en ;
             skos:definition "Hardening (3.167) of a workpiece, followed by tempering, in order to produce a condition characterised by a good combination of hardness and toughness."@en ,
                             "Härtung (3.167) eines Werkstückes mit anschließendem Anlassen, um einen Zustand zu erzeugen, der durch eine gute Kombination von Härte und Zähigkeit gekennzeichnet ist."@de .

_:genid27 owl:intersectionOf ( :HTO_0000020
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty obo:BFO_0000051 ;
                                  owl:someValuesFrom :HTO_0000038
                                ]
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty obo:BFO_0000051 ;
                                  owl:someValuesFrom :HTO_0000040
                                ]
                              ) ;
           rdf:type owl:Class .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :HTO_0000022 ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid27 ;
   obo:IAO_0000116 "this axiom should also include the order of the process (hardening precedes tempering)"
 ] .


###  https://w3id.org/pmd/hto/HTO_0000023
:HTO_0000023 rdf:type owl:Class ;
             terms:source "DIN 17022-1:1994, §5.4" ,
                          "DIN 17022-5:2000, §6.5" ,
                          "DIN EN ISO 4885:2018, §3.203" ,
                          "DIN EN ISO 683-2:2018, Tab.11" ,
                          "DIN EN ISO 683-3:2022, Tab.8" ;
             rdfs:comment "add target temperature in axioms" ;
             rdfs:label "tempering recipe"@en ;
             skos:definition "A heat treatment recipe outlining the steps and parameters for carrying out a tempering process."@en ,
                             "Wärmebehandlungsrezept, in dem die Schritte und Parameter zur Durchführung eines Anlassprozesses beschrieben werden."@de .


###  https://w3id.org/pmd/hto/HTO_0000024
:HTO_0000024 rdf:type owl:Class ;
             rdfs:subClassOf :HTO_0000041 ;
             terms:source "DIN 17022-4:1998, §7.3" ;
             rdfs:label "plasma nitriding"@en ;
             skos:definition "Nitriding (3.143) at a pressure that is usually below atmospheric pressure, using a plasma carrier to ionise the nitrogen."@en ,
                             "Nitrieren (3.143) bei einem Druck, der üblicherweise unter dem Atmosphärendruck liegt und mit einem Plasmaträger, um den Stickstoff zu ionisieren"@en ,
                             "A nitriding process in which nitrogen is supplied to the surface via the acceleration of ionised nitrogen." .


###  https://w3id.org/pmd/hto/HTO_0000025
:HTO_0000025 rdf:type owl:Class ;
             rdfs:subClassOf :HTO_0000019 ;
             terms:source "DIN EN ISO 4885:2018, §3.36" ;
             rdfs:label "Aufkohlen"@de ,
                        "carburizing"@en ;
             skos:altLabel "Karburieren"@de ;
             skos:definition "Thermochemical treatment (3.207) to enrich the surface of an austenitised workpiece with carbon, which is then present in solid solution in austenite (3.12)."@en ,
                             "Thermochemische Behandlung (3.207) zum Anreichern der Oberfläche eines austenitisierten Werkstückes mit Kohlenstoff, der dann im Austenit (3.12) in fester Lösung vorliegt."@de ,
                             "A surface hardening process in which carbon is supplied to a material's surface with the goal to increase the carbon content in the surface of a sample or part." ;
             skos:editorialNote "DIN audit fix (2026-06-09): hto-edit.owl's existing rdfs:comment/skos:definition treats Aufkohlen as a 'surface hardening process'; DIN EN ISO 4885 §3.36 defines it as 'thermochemische Behandlung zum Anreichern der Oberfläche eines austenitisierten Werkstückes mit Kohlenstoff'. Hardening only follows IF quenching is subsequently applied (cf. §3.37 Einsatzhärten = Aufkohlen + Härten). Original rdfs:label preserved; the §3.36 verbatim definition is added via skos:definition as the canonical anchor."@en .


###  https://w3id.org/pmd/hto/HTO_0000026
:HTO_0000026 rdf:type owl:Class ;
             rdfs:subClassOf :HTO_0000041 ;
             terms:source "DIN 17022-4:1998, §7.3" ,
                          "DIN EN ISO 4885:2018, §3.143 (inline)" ;
             rdfs:label "Gasnitrieren"@de ,
                        "gas nitriding"@en ;
             skos:definition "A nitriding process where nitrogen is supplied to the surface in gaseous form." .


###  https://w3id.org/pmd/hto/HTO_0000027
:HTO_0000027 rdf:type owl:Class ;
             rdfs:subClassOf :HTO_0000032 ;
