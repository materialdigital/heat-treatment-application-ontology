###  https://w3id.org/pmd/hto/HTO_0000030
:HTO_0000030 rdf:type owl:Class ;
             rdfs:subClassOf :HTO_0000005 ;
             terms:source "DIN 17022-1:1994, Bild 5" ,
                          "DIN 17022-1:1994, §3.1.1 (Aufheizgeschwindigkeit)" ;
             rdfs:label "heating rate"@en ;
             skos:definition "A temperature change rate that is of positive value." .


###  https://w3id.org/pmd/hto/HTO_0000031
:HTO_0000031 rdf:type owl:Class ;
             rdfs:subClassOf :HTO_0000005 ;
             terms:source "DIN 17022-1:1994, §5.2.2 (Abkühlgeschwindigkeit)" ,
                          "DIN EN ISO 4885:2018, §3.52 (kritische Abkühlgeschwindigkeit)" ;
