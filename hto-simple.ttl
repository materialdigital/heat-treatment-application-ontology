             skos:definition "A setpoint describing the pressure that is to be reached/held within a process that involves a defined pressure." ;
             skos:editorialNote "needs work" .


###  https://w3id.org/pmd/hto/HTO_0000028
:HTO_0000028 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty obo:RO_0000085 ;
                               owl:someValuesFrom :HTO_0000029
                             ] ;
