:HTO_0000044 rdf:type owl:Class ;
             rdfs:subClassOf :HTO_0000043 ;
             owl:disjointWith :HTO_0000045 ;
             rdfs:comment "the mechanical energy needed for machines to work is supplied by engines/motors" ;
