###  https://w3id.org/pmd/co/PMD_0000056
co:PMD_0000056 owl:equivalentClass [ owl:intersectionOf ( co:PMD_0000655
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty obo:RO_0000085 ;
                                                            owl:someValuesFrom co:PMD_0000057
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] .


###  https://w3id.org/pmd/co/PMD_0000655
co:PMD_0000655 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty obo:BFO_0000051 ;
                                 owl:someValuesFrom hto:Chamber
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty obo:RO_0000085 ;
                                 owl:someValuesFrom co:PMD_0000054
                               ] .


###  https://w3id.org/pmd/co/PMD_0025010
co:PMD_0025010 rdfs:subClassOf hto:HTO_0000000 ;
               dc:source "DIN EN ISO 4885:2018, §3.109 (thnlrd)" ;
               rdfs:label "Erwärmen"@de ;
               skos:comment "Das Erwärmen kann kontinuierlich, nicht kontinuierlich oder allmählich in einem Schritt oder in mehreren Schritten erfolgen."@de ,
                            "Heating may be continuous, non-continuos or gradually in one or more steps." .


###  https://w3id.org/pmd/co/PMD_0025011
co:PMD_0025011 rdfs:subClassOf hto:HTO_0000000 ;
               dc:source "DIN EN ISO 4885:2018, §3.45" ;
               skos:definition "entweder kontinuierliche, nicht kontinuierliche, stufenweise, allmähliche oder unterbrochene Senkung (oder Behandlung zur Senkung) der Temperatur eines heißen Werkstückes"@de .


###  https://w3id.org/pmd/co/PMD_0060009
co:PMD_0060009 obo:IAO_0000115 "Ein Sollwert ist ein Spezifikationswert, der einem geregelten Prozessparameter einen gewünschten quantitativen Wert zuweist und als normgebende Referenz für die Prozessausführung und -steuerung dient."@de .


###  https://w3id.org/pmd/hto/AccelleratedCooling
hto:AccelleratedCooling rdf:type owl:Class ;
                        obo:IAO_0000114 "needs work" ;
                        rdfs:comment "Achieved via convection only."@en ,
                                     "The reason for obsoletion is that the term is not clearly defined and usage has been inconsistent." ,
                                     "so convection cooling is a function of a device, it could be realized in a cooling process. definatl needs a better name like acllerated convection cooling function, to be specific" ;
                        rdfs:isDefinedBy hto: ;
                        rdfs:label "obsolete accellerated cooling"@en ;
                        owl:deprecated "true"^^xsd:boolean ;
                        skos:definition "Status of the cooling method active e.g., at the end of the nitriding process"@en .


###  https://w3id.org/pmd/hto/AcquisitionDate
hto:AcquisitionDate rdf:type owl:Class ;
                    obo:IAO_0000114 "needs work" ;
                    rdfs:comment "The reason for obsoletion is that the term is not clearly defined and of uncertain relevance." ,
                                 "is a temperal instant!" ;
                    rdfs:isDefinedBy hto: ;
                    rdfs:label "obsolete acquisition date"@en ;
                    owl:deprecated "true"^^xsd:boolean ;
                    skos:definition "The point in time a Process Node was commissioned (e.g., the purchase date, first day of use), represented in IEEE 1003 'Seconds since Epoch'. "@en .


###  https://w3id.org/pmd/hto/Atmosphere
hto:Atmosphere rdf:type owl:Class ;
               <http://www.geneontology.org/formats/oboInOwl#consider> co:PMD_0020113 ;
               rdfs:comment "The reason for obsoletion is that the meaning of the term is ambiguous." ;
               rdfs:label "obsolete atmosphere"@en ;
               owl:deprecated "true"^^xsd:boolean ;
               skos:definition "A surrounding influence or environment" .


###  https://w3id.org/pmd/hto/AtmospherePressure
hto:AtmospherePressure rdf:type owl:Class ;
                       rdfs:subClassOf co:PMD_0000896 ;
                       owl:disjointWith hto:ChamberPressure ;
                       dc:source "DIN 17022-4:1998, §7.3" ,
                                 "DIN EN ISO 4885:2018, §3.165 (Ofenatmosphäre, related quality)" ;
                       rdfs:comment "Effective atmosphere preasure in chamber to keep process save (must be 2-3 mbar above ambient pressure)"@en ,
                                    "Parameter usually slightly higher than ambient pressure for open process to environment to prevent/reduce diffusion of oxygen into the furnace, e.g. by leakage, to avoid explosive or dangerous atmopheres, could be bar, mbar or Pa."@en ;
                       rdfs:isDefinedBy hto: ;
                       rdfs:label "atmosphere pressure"@en ;
                       skos:definition "Parameter describing the pressure inside a chamber."@en .


###  https://w3id.org/pmd/hto/BelowAmbientPressure
hto:BelowAmbientPressure rdf:type owl:Class ;
                         rdfs:comment "The reason for obsoletion is that the term is not clearly defined and of uncertain relevance." ;
                         rdfs:isDefinedBy hto: ;
                         rdfs:label "obsolete below ambient pressure"@en ;
                         owl:deprecated "true"^^xsd:boolean ;
                         skos:definition "status of atmosphere: reduced pressure below ambient pressure "@en .


###  https://w3id.org/pmd/hto/CarbonPotential
hto:CarbonPotential rdf:type owl:Class ;
                    rdfs:subClassOf obo:BFO_0000145 ;
                    dc:source "DIN EN ISO 4885:2018, §3.33 (Kohlenstoffpegel — contrast Anm.1)" ,
                              "DIN EN ISO 683-3:2022, §A.4 (carburising atmosphere control)" ;
                    rdfs:comment "Nitrocarburieren mit Kohlenstoffträger, aus Messwerten abgeleitet KC"@de ,
                                 "See standard DIN 1310"@en ;
                    rdfs:isDefinedBy hto: ;
                    rdfs:label "carbon potential"@en ;
                    skos:definition "Carbon content of a specimen of pure iron in equilibrium with a carbourizing medium under specific conditions."@en ;
                    skos:editorialNote "DIN audit (2026-06-09): DIN EN ISO 4885 §3.33 names the operational quantity 'Kohlenstoffpegel' (carbon level), with §3.33 Anm.1 contrasting it explicitly with the 'thermodynamisches Kohlenstoffpotenzial'. 4885 treats the two as NOT synonymous. hto:CarbonPotential is retained as the thermodynamic-potential quality; the new sibling hto:HTO_0000076 (CarbonLevel) carries the §3.33 operational definition. See hto:HTO_0000076 below for the sibling class."@en .


###  https://w3id.org/pmd/hto/Carburizing
hto:Carburizing rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0060008 ;
                obo:IAO_0000116 "needs work" ;
                dc:source "DIN 17022-3:2025-11, §6" ;
                rdfs:comment "Potentiell ableitbar mit bestimmten Fluss-Schwellenwerten"@de ;
                rdfs:isDefinedBy hto: ;
                rdfs:label "Aufkohlungsrezept"@de ,
                           "carburizing recipe"@en ;
                skos:definition "Heattreatment recipe outlining the steps and parameters needed to perform a carburizing process."@en ,
                                "Wärmebehandlungsrezept, in dem die Schritte und Parameter für die Durchführung eines Aufkohlungsprozesses beschrieben werden."@de .


###  https://w3id.org/pmd/hto/Chamber
hto:Chamber rdf:type owl:Class ;
            rdfs:subClassOf obo:BFO_0000024 ;
            obo:IAO_0000114 "needs work" ;
            dc:source "DIN 17022-1:1994, §7 (generic multi-chamber furnace construction)" ;
            rdfs:comment "unklare Zuordnung innerhalb der SDCs. Eine Kammer existiert nur als Teil eines Gerätes (Device), könnte aber selbst noch einmal als independent continuant definiert werden, da sich in der Kammer Chargen, Gestelle, Thermoelemente etc. befinden."@de ,
                         "moved to fiat object part. correct if every furnace has a chamber" ;
            rdfs:isDefinedBy hto: ;
            rdfs:label "chamber"@en ;
            skos:definition "Systemboundary of a distinct Heattreatment Process. Includes a fluid that has the role of medium role (e.g., Helium or Vacuum)."@en .


###  https://w3id.org/pmd/hto/ChamberPressure
hto:ChamberPressure rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( co:PMD_0000896
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty obo:RO_0000080 ;
                                                                 owl:someValuesFrom hto:Chamber
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    dc:source "DIN 17022-1:1994, §7 (chamber/Ofen-Konstruktion)" ,
                              "DIN 17022-4:1998, §7.3 (Ofendruck)" ;
                    rdfs:comment "measured atmophere pressure in retort, measured using the vacuum sensor "@en ;
                    rdfs:isDefinedBy hto: ;
                    rdfs:label "chamber pressure"@en ;
                    skos:definition "designated pressure in retort during evacuation phase pre to nitriding process or during low pressure nitriding process "@en .


###  https://w3id.org/pmd/hto/ChamberScope
hto:ChamberScope rdf:type owl:Class ;
                 rdfs:subClassOf obo:BFO_0000023 ;
                 obo:IAO_0000114 "needs work" ;
                 rdfs:comment "Sollte mit Unit-Volume (m^3) verbunden sein"@de ,
                              "The reason for obsoletion is that the term is not clearly defined and usage has been inconsistent." ,
                              "competly dont get that one" ;
                 rdfs:isDefinedBy hto: ;
                 rdfs:label "obsolete Wärmebehandlungsofenkammer"@de ,
                            "obsolete chamberscope"@en ;
                 owl:deprecated "true"^^xsd:boolean ;
                 skos:definition "Funktionale Ofenkammer."@de ,
                                 "OBSOLETE. Functional furnace chamber."@en ,
                                 """OBSOLETE. Position of the batch in a multi-chamber furnace
A specialization of hasProcessNodeComponent representing distinguishable heat treatment chambers of a furnaces.
can be: heating chamber / cooling chamber"""@en .


###  https://w3id.org/pmd/hto/CollectionInterfaceHint
hto:CollectionInterfaceHint rdf:type owl:Class ;
                            rdfs:comment "The reason for obsoletion is that the term is not clearly defined and of uncertain relevance." ;
                            rdfs:isDefinedBy hto: ;
                            rdfs:label "obsolete collection interface hint"@en ;
                            owl:deprecated "true"^^xsd:boolean ;
                            skos:definition "A label in support of identifying a network interface and/or address used by a process node to provide primary data stored in ontologies "@en .


###  https://w3id.org/pmd/hto/ConcentrationH2
hto:ConcentrationH2 rdf:type owl:Class ;
                    <http://www.geneontology.org/formats/oboInOwl#consider> obo:IAO_0000005 ;
                    rdfs:comment "Ammonia is usually intenionally induced;"@en ,
                                 "Einzelne Werte durch auf das Molekül spezifizierte Messsonden."@de ,
                                 "Might be calculated from model or measurement."@en ,
                                 "Oxygen concentration in process gas composition, oxygen can be formed during decomposition of e.g. carbon monoxide or dioxide or can be intenionally induced e.g. as air, synthetic air or water or enters the furnace via leckage."@en ,
                                 "Water concentration in process gas composition, if nominal water is intenionally induced; units could be e.g. mol/m³ or °C; signal could be in mA or mV or in vol.-% or °C (dew point)"@en ,
                                 "Hydrogen can be formed during decomposition of e.g. ammonia, acetylene or can be intenionally induced e.g. in forming gas." ,
                                 "The reason for obsoletion is that the term is not clearly defined." ;
                    rdfs:isDefinedBy hto: ;
                    rdfs:label "obsolete concentration"@en ;
                    owl:deprecated "true"^^xsd:boolean ;
                    skos:definition "Concentration in process gas composition; units could be e.g. mol/m³; signal could be in mA or mV or in vol.-%"@en .


###  https://w3id.org/pmd/hto/Controlled
hto:Controlled rdf:type owl:Class ;
               rdfs:subClassOf hto:HTO_0000033 ;
               rdfs:comment "definition is not enough, what is controlled?" ;
               rdfs:isDefinedBy hto: ;
               rdfs:label "controlled"@en ;
               owl:deprecated "true"^^xsd:boolean ;
               skos:definition "This Scope expresses that a :ValueObject is actively controlled during the process, e.g. a heating process where the temperature change is done in controlled intervals until the desired temperature is reached while an uncontrolled heating process would reach the desired temperature as fast as the furnace allows it to."@en .


###  https://w3id.org/pmd/hto/Convection
hto:Convection rdf:type owl:Class ;
               rdfs:subClassOf hto:HTO_0000033 ;
               rdfs:comment "if its a device specification to run a heat up process by some spefiic mode of action, then pls change the definition" ;
               rdfs:isDefinedBy hto: ;
               rdfs:label "convection"@en ;
               owl:deprecated "true"^^xsd:boolean ;
               skos:definition "konvection during heating, heating in atmosphere, not in vacuum "@en .


###  https://w3id.org/pmd/hto/DewPoint
hto:DewPoint rdf:type owl:Class ;
             rdfs:subClassOf obo:IAO_0000109 ;
             dc:source "DIN EN ISO 683-3:2022, §A.4 Anm. (Taupunkt as carburising atmosphere control variable)" ;
             rdfs:isDefinedBy hto: ;
             rdfs:label "dew point"@en ;
             skos:definition "dew point of the atmosphere, measured during process or calculated from lambda / oxygen probe signal "@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource hto:DewPoint ;
   owl:annotatedProperty dc:source ;
   owl:annotatedTarget "DIN EN ISO 683-3:2022, §A.4 Anm. (Taupunkt as carburising atmosphere control variable)" ;
   obo:IAO_0000116 "the source given (DIN EN ISO 683-3) does not contain info about dew points (thoni)"
 ] .


###  https://w3id.org/pmd/hto/DurationTillTargetTemperature
hto:DurationTillTargetTemperature rdf:type owl:Class ;
                                  rdfs:comment "Erwärmdauer = Heizzeit + Durchwärmdauer"@de ,
                                               "Maß für die tatsächliche Dauer eines Erwärmvorgangs."@de ,
                                               "The reason for obsoletion is that the term is not clearly defined." ;
                                  rdfs:isDefinedBy hto: ;
                                  rdfs:label "obsolete Erwärmdauer"@de ,
                                             "obsolete duration till target temperature"@en ;
                                  owl:deprecated "true"^^xsd:boolean ;
                                  skos:definition "Measurement representing the actual duration of a heating procedure."@en .


###  https://w3id.org/pmd/hto/DurationToReachTargetTemperature
