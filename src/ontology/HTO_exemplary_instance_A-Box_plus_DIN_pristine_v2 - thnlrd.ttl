                rdfs:subClassOf co:PMD_0000781 ;
                obo:IAO_0000116 "A heat treatment function to decrease a volumes pressure to vacuum, removing possibly present gases and fluids." ;
                dc:source "DIN 17022-4:1998, §7.3" ;
                rdfs:label "evacuation function"@en .


