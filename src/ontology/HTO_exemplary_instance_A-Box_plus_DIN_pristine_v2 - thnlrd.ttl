###  https://w3id.org/pmd/hto/FanStateFast
hto:FanStateFast rdf:type owl:Class ;
                 rdfs:subClassOf hto:HTO_0000033 ;
                 obo:IAO_0000114 "needs work" ;
                 rdfs:label "fan state fast"@en ;
                 owl:deprecated "true"^^xsd:boolean ;
