                                     <http://www.geneontology.org/formats/oboInOwl#consider> hto:HTO_0000009 ;
                                     rdfs:comment "The reason for obsoletion is that the term is not clearly defined or of unclear importance." ;
                                     rdfs:isDefinedBy hto: ;
                                     rdfs:label "obsolete duration to reach target temperature"@en ;
                                     owl:deprecated "true"^^xsd:boolean ;
                                     skos:definition "Parameter representing a derived duration of a heat up segment (in hours, minutes or seconds) "@en .


