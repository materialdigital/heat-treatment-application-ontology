<https://w3id.org/pmd/hto/hto-full.ttl> rdf:type owl:Ontology ;
                                         owl:versionIRI <https://w3id.org/pmd/hto/releases/2026-07-07/hto-full.ttl> ;
                                         dcterms:contributor <https://orcid.org/0000-0003-1649-6832> ;
                                         dcterms:creator <https://orcid.org/0000-0002-9014-2920> ,
                                                         <https://orcid.org/0009-0004-4787-4685> ,
                                                         "Divya Gosula" ;
                                         dcterms:description "This ontology module is part of the Platform Material Digital Application Ontology (PMDao) and covers concepts related to heat treatment processes, parameters, and materials. It is designed to facilitate data integration, sharing, and analysis in the field of materials science and engineering, particularly focusing on heat treatment applications."@en ;
                                         dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
                                         dcterms:title "Platform Material Digital Application Ontology (PMDao) - Heat Treatment Module"@en ;
                                         owl:versionInfo "2026-07-07" .

