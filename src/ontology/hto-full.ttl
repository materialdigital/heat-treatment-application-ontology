###  https://w3id.org/pmd/co/PMD_0090015
co:PMD_0090015 rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( co:PMD_0000127
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty obo:RO_0002353 ;
