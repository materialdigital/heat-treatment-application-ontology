                obo:IAO_0000119 "Person: Jie Zheng, Chris Stoeckert, Alan Ruttenberg"@en ;
                rdfs:comment "The 'tracker item' can associate a tracker with a specific ontology term."@en ;
                rdfs:label "term tracker item"@en .


