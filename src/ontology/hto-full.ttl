                                  owl:someValuesFrom obo:OBI_0000067
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty obo:OBI_0000293 ;
                                  owl:someValuesFrom [ owl:intersectionOf ( obo:BFO_0000040
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty obo:RO_0000087 ;
