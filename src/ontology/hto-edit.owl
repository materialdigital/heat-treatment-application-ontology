###  https://w3id.org/pmd/hto/HTO_0000024
hto:HTO_0000024 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000041 ;
                dc:source "DIN 17022-4:1998, §7.3" ;
                rdfs:label "plasma nitriding"@en ;
                skos:definition "Nitriding (3.143) at a pressure that is usually below atmospheric pressure, using a plasma carrier to ionise the nitrogen."@en ,
                                "Nitrieren (3.143) bei einem Druck, der üblicherweise unter dem Atmosphärendruck liegt und mit einem Plasmaträger, um den Stickstoff zu ionisieren"@en ,
                                "A nitriding process in which nitrogen is supplied to the surface via the acceleration of ionised nitrogen." .


###  https://w3id.org/pmd/hto/HTO_0000025
hto:HTO_0000025 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000019 ;
                dc:source "DIN EN ISO 4885:2018, §3.36" ;
                rdfs:label "Aufkohlen"@de ,
                           "carburizing"@en ;
                skos:altLabel "Karburieren"@de ;
                skos:definition "Thermochemical treatment (3.207) to enrich the surface of an austenitised workpiece with carbon, which is then present in solid solution in austenite (3.12)."@en ,
                                "Thermochemische Behandlung (3.207) zum Anreichern der Oberfläche eines austenitisierten Werkstückes mit Kohlenstoff, der dann im Austenit (3.12) in fester Lösung vorliegt."@de ,
                                "A surface hardening process in which carbon is supplied to a material's surface with the goal to increase the carbon content in the surface of a sample or part." ;
                skos:editorialNote "DIN audit fix (2026-06-09): hto-edit.owl's existing rdfs:comment/skos:definition treats Aufkohlen as a 'surface hardening process'; DIN EN ISO 4885 §3.36 defines it as 'thermochemische Behandlung zum Anreichern der Oberfläche eines austenitisierten Werkstückes mit Kohlenstoff'. Hardening only follows IF quenching is subsequently applied (cf. §3.37 Einsatzhärten = Aufkohlen + Härten). Original rdfs:label preserved; the §3.36 verbatim definition is added via skos:definition as the canonical anchor."@en .


