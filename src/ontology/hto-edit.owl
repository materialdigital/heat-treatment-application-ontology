AnnotationAssertion(rdfs:label hto:HTO_0000020 "Durchhärten"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000020 "through hardening"@en)
AnnotationAssertion(skos:definition hto:HTO_0000020 "Hardening (3.167), in which the formation of martensite (3.137) extends right to the core of a workpiece.")
AnnotationAssertion(skos:definition hto:HTO_0000020 "Härtung (3.167), bei der die Bildung von Martensit (3.137) bis zum Kern eines Werkstückes erreicht wird."@de)
SubClassOf(hto:HTO_0000020 hto:HTO_0000040)

