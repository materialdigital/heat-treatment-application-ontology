# Class: hto:HTO_0000019 (Oberflächenhärtung)

AnnotationAssertion(dcterms:source hto:HTO_0000019 "DIN 17022-5:2000, §1")
AnnotationAssertion(dcterms:source hto:HTO_0000019 "DIN 17022-5:2000, §4")
AnnotationAssertion(dcterms:source hto:HTO_0000019 "DIN EN ISO 4885:2018, §3.200")
AnnotationAssertion(rdfs:label hto:HTO_0000019 "Oberflächenhärtung"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000019 "surface hardening"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000019 "Oberflächenhärtung"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000019 "Randschichthärtung"@de)
AnnotationAssertion(skos:definition hto:HTO_0000019 "Auf die Randschicht beschränkte Härtung (3.167)."@de)
AnnotationAssertion(skos:definition hto:HTO_0000019 "Hardening (3.167) restricted to the surface layer."@en)
AnnotationAssertion(skos:definition hto:HTO_0000019 "Hardening process where only the surface of a part and not its entire volume is hardened.")
AnnotationAssertion(skos:editorialNote hto:HTO_0000019 "DIN audit fix (2026-06-09): DIN EN ISO 4885 §3.200 lemma is 'Randschichthärten'; DIN 17022-5 uses 'Randschichthärten' exclusively in its title. The hto-edit.owl DE label 'Oberflächenhärtung' is a DIN-10052 / legacy synonym (already retained in hto-edit.owl as skos:altLabel — preserved here). The DIN-canonical 'Randschichthärten' is hoisted to skos:prefLabel."@en)
SubClassOf(hto:HTO_0000019 hto:HTO_0000040)
DisjointClasses(hto:HTO_0000019 hto:HTO_0000020)

# Class: hto:HTO_0000020 (through hardening)

