#################################################################
#    Classes
#################################################################

###  https://w3id.org/pmd/co/PMD_0000056
co:PMD_0000056 owl:equivalentClass [ owl:intersectionOf ( co:PMD_0000655
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty obo:RO_0000085 ;
                                                            owl:someValuesFrom co:PMD_0000057
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] .


###  https://w3id.org/pmd/co/PMD_0000655
co:PMD_0000655 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty obo:BFO_0000051 ;
                                 owl:someValuesFrom hto:HTO_0000109
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty obo:RO_0000085 ;
                                 owl:someValuesFrom co:PMD_0000054
                               ] .


###  https://w3id.org/pmd/co/PMD_0025010
co:PMD_0025010 rdfs:subClassOf hto:HTO_0000000 ;
               dc:source "DIN EN ISO 4885:2018, §3.109 (thnlrd)" ;
               rdfs:label "Erwärmen"@de ;
               skos:altLabel "Aufheizen" ;
               skos:comment "Das Erwärmen kann kontinuierlich, nicht kontinuierlich oder allmählich in einem Schritt oder in mehreren Schritten erfolgen."@de ,
                            "Heating may be continuous, non-continuos or gradually in one or more steps." ;
               skos:definition "Essential heat treatment process where an increase in temperature takes place." .


###  https://w3id.org/pmd/co/PMD_0025011
co:PMD_0025011 rdfs:subClassOf hto:HTO_0000000 ;
               dc:source "DIN EN ISO 4885:2018, §3.45" ;
               skos:definition "entweder kontinuierliche, nicht kontinuierliche, stufenweise, allmähliche oder unterbrochene Senkung (oder Behandlung zur Senkung) der Temperatur eines heißen Werkstückes"@de .


###  https://w3id.org/pmd/hto/HTO_0000000
hto:HTO_0000000 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000833 ;
                dc:source "DIN EN ISO 4885:2018, §3 (generic upper-level HT-process taxonomy)" ,
                          "DIN EN ISO 4885:2018, §3.167 (Härtung)" ,
                          "DIN EN ISO 4885:2018, §3.207 (thermochemische Behandlung)" ,
                          "DIN EN ISO 4885:2018, §3.8 (Glühen)" ;
                rdfs:comment "intermediate class/grouping term, not to be instatialized"@en ;
                rdfs:label "Grundsätzlicher Wärmebehandlungsvorgang"@de ,
                           "essential heat treatment process"@en ;
                skos:definition "Essential processes that make up heat treatments and can be used like building blocks."@en .


###  https://w3id.org/pmd/hto/HTO_0000001
hto:HTO_0000001 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000055 ;
                dc:source "DIN 17022-1:1994, §3.1.2" ,
                          "DIN EN ISO 4885:2018, §3.168" ;
                rdfs:label "quenching function"@en ;
                skos:definition "A quenching function is a (realizable) function that, when realized, enables a system to lower the temparature of a material fast enough, that it hinders diffusion processes and thus produces metastable material states."@en ,
                                "Eine Abschreckfunktion ist eine (realisierbare) Funktion, die es einem System ermöglicht die Temperatur eines Material schnell genug abzusenken, sodass Diffusionsprozesse behindert und dadurch metastabile Materialzustände erzeugt werden."@de ;
                skos:example "The function of a oil bath to quench steel after austenitisation so the material transforms into martensite."@en .


###  https://w3id.org/pmd/hto/HTO_0000003
hto:HTO_0000003 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000032 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty obo:IAO_0000136 ;
                                  owl:someValuesFrom hto:HTO_0000005
                                ] ;
                dc:source "DIN 17022-1:1994, §3.1.1" ,
                          "DIN 17022-1:1994, §5.2.2" ;
                rdfs:label "temperature change rate specification"@en ;
                skos:definition "A setpoint which - as part of plan specifications (e.g. recipes) - specifies the rate at which temparature is to be changed." .


###  https://w3id.org/pmd/hto/HTO_0000004
hto:HTO_0000004 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0060008 ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty obo:BFO_0000051 ;
                                                         owl:someValuesFrom hto:HTO_0000003
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty obo:BFO_0000051 ;
                                                         owl:someValuesFrom hto:HTO_0000006
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                dc:source "DIN 17022-1:1994, §3.1.1" ;
                rdfs:label "heating recipe"@en ;
                skos:definition "A heat treatment recipe describing the steps and parameters for carrying out a heating process."@en ,
                                "Wärmebehandlungsrezept mit dem die Schritte und Parameter zur Durchführung eines Aufheizprozesses beschrieben werden."@de .


###  https://w3id.org/pmd/hto/HTO_0000005
hto:HTO_0000005 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000008 ;
                dc:source "DIN 17022-1:1994, §3.1.1" ,
                          "DIN 17022-1:1994, §5.2.2 (incl. kritische Abkühlgeschwindigkeit K_k)" ;
                rdfs:label "temperature change rate"@en ;
                skos:definition "A process attribute defining the change of temperature per time unit within a process."@en .


###  https://w3id.org/pmd/hto/HTO_0000006
hto:HTO_0000006 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000032 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty obo:IAO_0000039 ;
                                  owl:someValuesFrom hto:HTO_0000010
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty obo:IAO_0000136 ;
                                  owl:someValuesFrom co:PMD_0000967
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty obo:OBI_0002135 ;
                                  owl:someValuesFrom xsd:float
                                ] ;
                dc:source "DIN 17022-1:1994, §5 (generic process-target temperature)" ;
                <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> "target temperature specification"@en ;
                rdfs:label "target temperature"@en ;
                skos:definition "A setpoint defining the temperature that is to be reached/held within a process that involves a defined temperature."@en ;
                skos:editorialNote "needs work" .


###  https://w3id.org/pmd/hto/HTO_0000008
hto:HTO_0000008 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000032 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty obo:IAO_0000136 ;
                                  owl:someValuesFrom hto:HTO_0000009
                                ] ;
                dc:source "DIN 17022-1:1994, Bild 1 (Verweildauer / Erwärm-/Anwärm-/Durchwärm-/Haltedauer)" ,
                          "DIN 17022-1:1994, §5.2.1" ,
                          "DIN EN ISO 683-2:2018, Tab.11 Fn d, f" ;
                rdfs:label "duration specification"@en ;
                skos:definition "Device specification as part of a plan specification which specifies the duration of a given process." .


###  https://w3id.org/pmd/hto/HTO_0000009
hto:HTO_0000009 rdf:type owl:Class ;
                rdfs:subClassOf obo:BFO_0000202 ;
                dc:source "DIN 17022-1:1994, Bild 1 (Verweildauer/Erwärm-/Anwärm-/Durchwärm-/Haltedauer)" ,
                          "DIN EN ISO 683-2:2018, Tab.11 (Anlassdauer / Aust.-dauer)" ;
                rdfs:label "duration"@en ;
                skos:definition "a temporal interval that describes the temporal extent of a process which is demarcated by the distance of two temporal instants"@en .


###  https://w3id.org/pmd/hto/HTO_0000010
hto:HTO_0000010 rdf:type owl:Class ;
                rdfs:subClassOf obo:IAO_0000003 ;
                dc:source "DIN EN ISO 4885:2018 (generic, °C usage throughout)" ;
                rdfs:comment "working variable, used for testing only" ;
                rdfs:label "temperature unit"@en .


###  https://w3id.org/pmd/hto/HTO_0000011
hto:HTO_0000011 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0020167 ;
                dc:source "DIN 17022-1:1994, §3.1.1" ,
                          "DIN EN ISO 4885:2018, §3.14" ,
                          "DIN EN ISO 4885:2018, §3.213" ,
                          "DIN EN ISO 683-5:2021, Tab.7 col.3" ;
                rdfs:comment "needs more work; austenitic phase can be reached from at least two temperatures for any given material (from liquid or from ferrite)" ;
                rdfs:label "austenitizing point"@en ;
                skos:definition "A realizable entity of a material which marks the phase change to austenite (γ-iron)." .


###  https://w3id.org/pmd/hto/HTO_0000012
hto:HTO_0000012 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000781 ;
                dc:source "DIN 17022-1:1994, Bild 1" ,
                          "DIN EN ISO 4885:2018, §3.185" ;
                rdfs:label "holding function"@en ;
                skos:definition "A heat treatment function that, enables a system or device to hold the thermal energy of a material, typically to facilitate diffusion and phase transformation processes within the material."@en ;
                skos:example "function of a furnace to hold its temperature at a specified temperature" .


###  https://w3id.org/pmd/hto/HTO_0000013
hto:HTO_0000013 rdf:type owl:Class ;
                rdfs:subClassOf [ owl:intersectionOf ( co:PMD_0060008
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty obo:BFO_0000051 ;
                                                         owl:someValuesFrom hto:HTO_0000004
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty obo:BFO_0000051 ;
                                                         owl:someValuesFrom hto:HTO_0000014
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty obo:BFO_0000051 ;
                                                         owl:someValuesFrom hto:HTO_0000015
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty obo:BFO_0000051 ;
                                                         owl:someValuesFrom hto:HTO_0000016
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                dc:source "DIN 17022-1:1994, §3.1" ,
                          "DIN EN ISO 683-2:2018, Tab.11" ,
                          "DIN EN ISO 683-3:2022, Tab.8" ;
                rdfs:comment "add target temperature in axioms, combine it with austenitisation temperature" ;
                rdfs:label "hardening recipe"@en ;
                skos:definition "A heat treatment recipe describing the steps and conditions for carrying out a hardening process."@en ,
                                "Wärmebehandlungsrezept mit dem Schritte und Parameter für die Durchführung eines Härtungsprozesses beschrieben werden."@de .


###  https://w3id.org/pmd/hto/HTO_0000014
hto:HTO_0000014 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0060008 ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty obo:BFO_0000051 ;
                                                         owl:someValuesFrom hto:HTO_0000006
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty obo:BFO_0000051 ;
                                                         owl:someValuesFrom hto:HTO_0000008
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                dc:source "DIN 17022-1:1994, §5.2.1" ,
                          "DIN EN ISO 4885:2018, §3.185" ;
                rdfs:label "holding recipe"@en ;
                skos:definition "A heat treatment recipe outlining the steps and parameters for carrying out a holding process."@en ,
                                "Wärmebehandlungsrezept, in dem die Schritte und Parameter zur Durchführung eines Halteprozesses beschrieben werden."@de .


###  https://w3id.org/pmd/hto/HTO_0000015
hto:HTO_0000015 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0060008 ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty obo:BFO_0000051 ;
                                                         owl:someValuesFrom hto:HTO_0000006
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty obo:BFO_0000051 ;
                                                         owl:someValuesFrom hto:HTO_0000008
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                dc:source "DIN 17022-1:1994, Bild 1 (Durchwärmdauer)" ,
                          "DIN EN ISO 4885:2018, §3.185" ;
                rdfs:label "soaking recipe"@en ;
                skos:definition "A heat treatment recipe outlining the steps and parameters for carrying out a soaking process."@en ,
                                "Wärmebehandlungsrezept, in dem die Schritte und Parameter zur Durchführung eines Durchwärmprozesses beschrieben werden."@de .


###  https://w3id.org/pmd/hto/HTO_0000016
hto:HTO_0000016 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000017 ;
                dc:source "DIN 17022-1:1994, §5.2.2" ,
                          "DIN EN ISO 4885:2018, §3.168" ;
                rdfs:label "quenching recipe"@en ;
                skos:definition "A heat treatment recipe describing the steps and conditions for carrying out a quenching process."@en ,
                                "Wärmebehandlungsrezept mit dem Schritte und Parameter für die Durchführung eines Abschreckprozesses beschrieben werden."@de .


###  https://w3id.org/pmd/hto/HTO_0000017
hto:HTO_0000017 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0060008 ;
                dc:source "DIN 17022-1:1994, §5.2.2" ,
                          "DIN EN ISO 4885:2018, §3.45" ;
                rdfs:label "Wärmebehandlungsrezept mit dem Schritte und Parameter für die Durchführung eines Abkühlungsprozesses beschrieben werden."@de ,
                           "cooling recipe"@en ;
                skos:definition "A heat treatment recipe describing the steps and parameters for carrying out a cooling process."@en .


###  https://w3id.org/pmd/hto/HTO_0000018
hto:HTO_0000018 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0060008 ;
                dc:source "DIN 17022-4:1998, §7" ;
                rdfs:label "nitriding recipe"@en ;
                skos:definition "A heat treatment recipe outlining the steps and parameters for carrying out a nitriding process."@en ,
                                "Wärmebehandlungsrezept, in dem die Schritte und Parameter zur Durchführung eines Nitrierprozesses beschrieben werden."@de .


###  https://w3id.org/pmd/hto/HTO_0000019
hto:HTO_0000019 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000040 ;
                owl:disjointWith hto:HTO_0000020 ;
                dc:source "DIN 17022-5:2000, §1" ,
                          "DIN 17022-5:2000, §4" ,
                          "DIN EN ISO 4885:2018, §3.200" ;
                rdfs:label "Oberflächenhärtung"@de ,
                           "surface hardening"@en ;
                skos:altLabel "Oberflächenhärtung"@de ,
                              "Randschichthärtung"@de ;
                skos:definition "Auf die Randschicht beschränkte Härtung (3.167)."@de ,
                                "Hardening (3.167) restricted to the surface layer."@en ,
                                "Hardening process where only the surface of a part and not its entire volume is hardened." ;
                skos:editorialNote "DIN audit fix (2026-06-09): DIN EN ISO 4885 §3.200 lemma is 'Randschichthärten'; DIN 17022-5 uses 'Randschichthärten' exclusively in its title. The hto-edit.owl DE label 'Oberflächenhärtung' is a DIN-10052 / legacy synonym (already retained in hto-edit.owl as skos:altLabel — preserved here). The DIN-canonical 'Randschichthärten' is hoisted to skos:prefLabel."@en .


