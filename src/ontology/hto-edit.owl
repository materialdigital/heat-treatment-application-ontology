AnnotationAssertion(rdfs:label hto:HTO_0000078 "Martensit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000078 "martensite"@en)
AnnotationAssertion(skos:definition hto:HTO_0000078 "Gefüge/Phase (3.156), die in kohlenstoffhaltigen Stählen durch Abkühlen (3.45) des Austenits (3.12) gebildet wird, wobei die hohe Geschwindigkeit des Abkühlens verhindert, dass ausreichend Kohlenstoffatome aus der Kristallstruktur diffundieren können, um Zementit (3.39) (Fe3C) zu bilden."@de)
AnnotationAssertion(skos:definition hto:HTO_0000078 "Microstructure/phase (3.156) formed in carbon-bearing steels by cooling (3.45) of austenite (3.12), where the high cooling rate prevents sufficient carbon atoms from diffusing out of the crystal structure to form cementite (3.39) (Fe3C)."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000078 "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.137 + Tabelle 1."@en)
SubClassOf(hto:HTO_0000078 co:PMD_0000857)

# Class: hto:HTO_0000079 (Bainit)

AnnotationAssertion(dcterms:source hto:HTO_0000079 "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)")
AnnotationAssertion(dcterms:source hto:HTO_0000079 "DIN EN ISO 4885:2018, §3.17")
AnnotationAssertion(rdfs:label hto:HTO_0000079 "Bainit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000079 "bainite"@en)
AnnotationAssertion(skos:definition hto:HTO_0000079 "Microstructure resulting from a transformation of austenite (3.12) at temperatures above the martensite (3.137) start temperature (Ms) and outside the range of pearlite (3.155), consisting of ferrite laths with carbides arranged either within (lower bainite) or between (upper bainite) the ferrite laths."@en)
AnnotationAssertion(skos:definition hto:HTO_0000079 "Mikrogefüge, das aus einer Umwandlung von Austenit (3.12) resultiert bei Temperaturen über die Starttemperatur (Ms) von Martensit (3.137) und außerhalb des Bereichs von Perlit (3.155), der aus Ferritlatten und Carbiden besteht, die entweder innerhalb der Ferritlatten (untere Bainite) oder zwischen den Ferritlatten angeordnet sind (obere Bainite)."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000079 "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.17 + Tabelle 1."@en)
SubClassOf(hto:HTO_0000079 co:PMD_0000857)

# Class: hto:HTO_0000080 (Ferrit)

AnnotationAssertion(dcterms:source hto:HTO_0000080 "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)")
AnnotationAssertion(dcterms:source hto:HTO_0000080 "DIN EN ISO 4885:2018, §3.85")
AnnotationAssertion(rdfs:label hto:HTO_0000080 "Ferrit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000080 "ferrite"@en)
AnnotationAssertion(skos:definition hto:HTO_0000080 "Gefüge von Eisen oder Stahl mit kubisch-raumzentrierter Gitterstruktur."@de)
AnnotationAssertion(skos:definition hto:HTO_0000080 "Microstructure of iron or steel with a body-centred cubic lattice structure."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000080 "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.85 + Tabelle 1."@en)
SubClassOf(hto:HTO_0000080 co:PMD_0000857)

# Class: hto:HTO_0000081 (Perlit)

AnnotationAssertion(dcterms:source hto:HTO_0000081 "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)")
AnnotationAssertion(dcterms:source hto:HTO_0000081 "DIN EN ISO 4885:2018, §3.155")
AnnotationAssertion(rdfs:label hto:HTO_0000081 "Perlit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000081 "pearlite"@en)
AnnotationAssertion(skos:definition hto:HTO_0000081 "Aus Ferrit- (3.85) und Zementit- (3.39) Lamellen bestehender Gefügebestandteil, der durch die eutektoidische Austenitumwandlung (3.56) und der gleichzeitig ablaufenden Transformation in Ferrit und Zementit gebildet wird."@de)
AnnotationAssertion(skos:definition hto:HTO_0000081 "Microstructure constituent consisting of ferrite (3.85) and cementite (3.39) lamellae, formed by the eutectoidic transformation of austenite (3.56) and the concomitant transformation into ferrite and cementite."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000081 "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.155 + Tabelle 1."@en)
SubClassOf(hto:HTO_0000081 co:PMD_0000857)

# Class: hto:HTO_0000082 (cementite)

AnnotationAssertion(dcterms:source hto:HTO_0000082 "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)")
AnnotationAssertion(dcterms:source hto:HTO_0000082 "DIN EN ISO 4885:2018, §3.39")
AnnotationAssertion(rdfs:label hto:HTO_0000082 "Zementit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000082 "cementite"@en)
AnnotationAssertion(skos:definition hto:HTO_0000082 "Microstructure composed of iron carbide with composition Fe3C."@en)
AnnotationAssertion(skos:definition hto:HTO_0000082 "Mokrogefüge, das das Carbid des Eisens, mit der Zusammensetzung Fe3C ist."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000082 "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.39 + Tabelle 1."@en)
SubClassOf(hto:HTO_0000082 co:PMD_0000857)

# Class: hto:HTO_0000083 (martensite start temperature)

AnnotationAssertion(dcterms:source hto:HTO_0000083 "DIN EN ISO 4885:2018, §3.213 Anm.1")
AnnotationAssertion(rdfs:label hto:HTO_0000083 "Martensit-Starttemperatur"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000083 "martensite start temperature"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000083 "M_s"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000083 "Ms"@de)
AnnotationAssertion(skos:definition hto:HTO_0000083 "Temperatur, bei der die Umwandlung von Austenit in Martensit (3.137) beim Abkühlen (3.45) beginnt."@de)
AnnotationAssertion(skos:definition hto:HTO_0000083 "Temperature at which the transformation of austenite into martensite (3.137) begins upon cooling (3.45)."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000083 "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1 (Bei Stählen können im Wesentlichen folgende Umwandlungstemperaturen unterschieden werden)."@en)
SubClassOf(hto:HTO_0000083 co:PMD_0020167)

# Class: hto:HTO_0000084 (martensite finish temperature)

AnnotationAssertion(dcterms:source hto:HTO_0000084 "DIN EN ISO 4885:2018, §3.213 Anm.1")
AnnotationAssertion(rdfs:label hto:HTO_0000084 "Martensit-Endtemperatur"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000084 "martensite finish temperature"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000084 "M_f"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000084 "Mf"@de)
AnnotationAssertion(skos:definition hto:HTO_0000084 "Temperatur, bei der die Umwandlung von Austenit in Martensit beim Abkühlen annähernd vollständig ist."@de)
AnnotationAssertion(skos:definition hto:HTO_0000084 "Temperature at which the transformation of austenite into martensite is approximately complete upon cooling."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000084 "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1."@en)
SubClassOf(hto:HTO_0000084 co:PMD_0020167)

# Class: hto:HTO_0000085 (A1-Temperatur)

AnnotationAssertion(dcterms:source hto:HTO_0000085 "DIN EN ISO 4885:2018, §3.213 Anm.1")
AnnotationAssertion(rdfs:label hto:HTO_0000085 "A1 transformation temperature"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000085 "A1-Temperatur"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000085 "A1"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000085 "A_1"@en)
AnnotationAssertion(skos:definition hto:HTO_0000085 "Equilibrium temperature defining the lower limit of austenite (3.12) existence."@en)
AnnotationAssertion(skos:definition hto:HTO_0000085 "Gleichgewichts-Temperatur, die die untere Grenze der Existenz von Austenit (3.12) festlegt."@de)
