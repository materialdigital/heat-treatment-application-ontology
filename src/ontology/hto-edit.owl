AnnotationAssertion(rdfs:label hto:HTO_0000106 "hardened material"@en)
EquivalentClasses(hto:HTO_0000106 ObjectIntersectionOf(co:PMD_0000000 ObjectSomeValuesFrom(obo:OBI_0000312 co:PMD_0000103)))

