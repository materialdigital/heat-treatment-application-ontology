AnnotationAssertion(skos:definition hto:HTO_0000034 "A categorical value specification defining the on/off state of some device."@en)
AnnotationAssertion(co:PMD_0000060 hto:HTO_0000034 "true"^^xsd:boolean)
SubClassOf(hto:HTO_0000034 obo:OBI_0001930)

# Class: hto:HTO_0000037 (salt bath nitriding)

AnnotationAssertion(dcterms:source hto:HTO_0000037 "DIN 17022-4:1998, §8")
AnnotationAssertion(dcterms:source hto:HTO_0000037 "DIN EN ISO 4885:2018, §3.143 (inline)")
AnnotationAssertion(rdfs:label hto:HTO_0000037 "Salzbadnitrieren"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000037 "salt bath nitriding"@en)
AnnotationAssertion(skos:definition hto:HTO_0000037 "A nitriding process in which nitrogen is supplied to the surface by molten salt.")
SubClassOf(hto:HTO_0000037 hto:HTO_0000041)

# Class: hto:HTO_0000038 (Anlassen)

AnnotationAssertion(dcterms:source hto:HTO_0000038 "DIN 17022-1:1994, §3.2")
AnnotationAssertion(dcterms:source hto:HTO_0000038 "DIN EN ISO 4885:2018, §3.203")
AnnotationAssertion(rdfs:label hto:HTO_0000038 "Anlassen"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000038 "tempering"@en)
AnnotationAssertion(skos:definition hto:HTO_0000038 "Heat treatment (3.108) of a steel product, generally carried out following hardening (3.167) or another heat treatment to achieve the required levels of properties, consisting of heating (3.109) to specific temperatures (< A1) and holding at these temperatures once or several times, followed by appropriate cooling (3.45)"@en)
AnnotationAssertion(skos:definition hto:HTO_0000038 "Wärmebehandlung (3.108) eines Eisenerzeugnisses, die im Allgemeinen nach einem Härten (3.167) oder einer anderen Wärmebehandlung zum Erreichen geforderter Stufen für Eigenschaften durchgeführt wird, bestehend aus Erwärmen (3.109) auf bestimmte Temperaturen (< A1) und einmaliges oder mehrmaliges Halten und anschließendem zweckentsprechendem Abkühlen (3.45)"@de)
SubClassOf(hto:HTO_0000038 ObjectIntersectionOf(co:PMD_0000779 ObjectSomeValuesFrom(obo:BFO_0000062 hto:HTO_0000040)))

# Class: hto:HTO_0000039 (Glühen)

AnnotationAssertion(dcterms:source hto:HTO_0000039 "DIN EN ISO 4885:2018, §3.8")
AnnotationAssertion(rdfs:label hto:HTO_0000039 "Glühen"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000039 "annealing"@en)
AnnotationAssertion(skos:definition hto:HTO_0000039 "Heat treatment (3.108), consisting of heating (3.109) and soaking (3.185) at a suitable temperature followed by cooling (3.45), such that an equilibrium-near microstructure is reached at room temperature."@en)
AnnotationAssertion(skos:definition hto:HTO_0000039 "Heat treatment process to form a specific microstructure or reduce residual stresses."@en)
AnnotationAssertion(skos:definition hto:HTO_0000039 "Wärmebehandlung (3.108), bestehend aus Erwärmen (3.109) und Halten (3.185) auf einer geeigneten Temperatur sowie Abkühlen (3.45), so dass sich bei Raumtemperatur ein dem Gleichgewicht angenäherter Gefügezustand einstellt."@de)
AnnotationAssertion(skos:definition hto:HTO_0000039 "Wärmebehandlung um eine bestimmte Gefügeausbildung zu erzielen oder Spannungen zu reduzieren."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000039 "DIN audit fix (2026-06-09): hto-edit.owl HTO_0000039 currently has only an @en label 'annealing' and no DE label. DIN EN ISO 4885 §3.8 lemma is 'Glühen'. The DE label is added via skos:prefLabel. NB: 4885 §3.8 Anm.1 organises Glühen as a parent of named children (Blankglühen, Normalglühen, Weichglühen, zwischenkritisches Glühen, isothermes Umwandeln, etc.); subclasses HTO_0000093..HTO_0000102 below populate this Glühen-family per DIN 683-7 §6.2.1 granularity contract."@en)
SubClassOf(hto:HTO_0000039 co:PMD_0000779)

# Class: hto:HTO_0000040 (Härtung durch Wärmebehandlung)

AnnotationAssertion(dcterms:source hto:HTO_0000040 "DIN 17022-1:1994, §3.1")
AnnotationAssertion(dcterms:source hto:HTO_0000040 "DIN EN ISO 4885:2018, §3.167")
AnnotationAssertion(rdfs:label hto:HTO_0000040 "Härtung durch Wärmebehandlung"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000040 "hardening heat treatment"@en)
AnnotationAssertion(skos:definition hto:HTO_0000040 "Heat treatment process to increase the strength and hardness of the material by cooling it so that its microstructure transforms to the hardening structure."@en)
AnnotationAssertion(skos:definition hto:HTO_0000040 "Prozess zur Härtung eines zuvor austenitisierten (3.14) Werkstückes, durch Abkühlen (3.45) unter Bedingungen erreicht, die geeignet sind, den Austenit (3.12) nahezu vollständig in Martensit (3.137) und gegebenenfalls Bainit (3.17) umzuwandeln."@de)
AnnotationAssertion(skos:definition hto:HTO_0000040 "Wärmebehandlungprozess durch den eine Härte- und Festigkeitssteigerung erreicht wird, in dem das Material mit solcher Geschwindikeit abgekühlt wird, dass ein Härtungsgefüge enstehen kann."@de)
AnnotationAssertion(skos:example hto:HTO_0000040 "Randschichthärten

Einsatzhärten
Nitrierhärten"@de)
SubClassOf(hto:HTO_0000040 co:PMD_0000779)
SubClassOf(hto:HTO_0000040 ObjectSomeValuesFrom(obo:RO_0000059 hto:HTO_0000013))

# Class: hto:HTO_0000041 (nitriding)

AnnotationAssertion(dcterms:source hto:HTO_0000041 "DIN EN ISO 4885:2018, §3.143")
AnnotationAssertion(rdfs:comment hto:HTO_0000041 "DIN parameter coupling (DIN EN ISO 683-5 Tab.7 ANMERKUNG verbatim): 'Die Anlasstemperatur sollte nicht weniger als 50 °C über der Nitriertemperatur liegen.' OWL 2 DL cannot directly express the cross-class arithmetic constraint Anlass-T(Vergüten preceding) >= Nitrier-T(this Nitrieren) + 50 degC; recommended downstream encoding is SHACL (constraint language) or SWRL (rule extension). This rdfs:comment is the pristine v2 deliverable for this constraint."@en)
AnnotationAssertion(rdfs:label hto:HTO_0000041 "Nitrieren"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000041 "nitriding"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000041 "Aufsticken"@de)
AnnotationAssertion(skos:definition hto:HTO_0000041 "A surface hardening process in which nitrogen is supplied to a material's surface with the goal to increase the nitrogen content in the surface of a sample or part."@en)
AnnotationAssertion(skos:definition hto:HTO_0000041 "Oberflächenhärtungsverfahren bei dem Stickstoff in flüssigem oder gasförmigem Zustand an eine Oberfläche gebracht wird, mit dem Ziel den Stickstoffgehalt in der Oberfläche des Materials zu erhöhen."@de)
AnnotationAssertion(skos:definition hto:HTO_0000041 "Thermochemical treatment (3.207) to produce hard surface layers on workpieces that contain nitrides."@en)
AnnotationAssertion(skos:definition hto:HTO_0000041 "Thermochemische Behandlung (3.207) zur Herstellung der harten Randschichten an Werkstücken, die Nitride enthalten."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000041 "DIN audit fix (2026-06-09): DIN EN ISO 4885 §3.143 lemma is 'Nitrieren'; DIN 17022-4, DIN 17022-5, and DIN EN ISO 683-5 all use 'Nitrieren' exclusively. The hto-edit.owl DE label 'Nitridieren' is a non-DIN morphological variant. The canonical 'Nitrieren' is hoisted to skos:prefLabel; the legacy 'Nitridieren' is demoted to skos:hiddenLabel."@en)
AnnotationAssertion(skos:hiddenLabel hto:HTO_0000041 "Nitridieren"@de)
SubClassOf(hto:HTO_0000041 co:PMD_0000779)
SubClassOf(hto:HTO_0000041 ObjectSomeValuesFrom(obo:BFO_0000062 hto:HTO_0000022))

# Class: hto:HTO_0000042 (equalization)

AnnotationAssertion(dcterms:source hto:HTO_0000042 "DIN 17022-1:1994, Bild 1 (Durchwärmdauer)")
AnnotationAssertion(dcterms:source hto:HTO_0000042 "DIN EN ISO 4885:2018, §3.80 (thnlrd)")
AnnotationAssertion(rdfs:comment hto:HTO_0000042 "Durchwärmen des Bauteils, sodass Temperaturhomogenität erreicht wird. Anschließend kann ein Halten auf der Zieltemperatur erfolgen.")
AnnotationAssertion(rdfs:label hto:HTO_0000042 "Durchwärmen"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000042 "equalization"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000042 "soaking"@en)
AnnotationAssertion(skos:definition hto:HTO_0000042 "Grundsätzlicher Wärmebehandlungsvorgang, während dessen die Temperaturhomogenisierung im Bauteil erreicht wird."@de)
AnnotationAssertion(skos:definition hto:HTO_0000042 "essential heat treatment process step during which temperature homogenization is achieved in the component."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000042 "In practice, the English terms 'equalization' and 'soaking' are synonymous. The standard DIN EN ISO 4885 is ambiguous about the distinction between 'Halten' (§3.185) and 'Durchwärmen' (3.80), and also translates 'soaking' as 'Halten'. The diagram for '§3.80 Durchwärmen' shows the two processes in sequence, whereas the annotation for 'Halten' states that the discrete location within an object must be specified. However, I deem this unnecessary, since 'Halten'/'holding' refers to the process that follows the soaking step and ensures a homogeneous temperature distribution regardless of the location.

(thnlrd)")
SubClassOf(hto:HTO_0000042 hto:HTO_0000000)

