# Annotation Property: dcterms:description (description)

AnnotationAssertion(rdfs:label dcterms:description "description")

# Annotation Property: dcterms:license (dcterms:license)

AnnotationAssertion(rdfs:label dcterms:license "license")

# Annotation Property: dcterms:title (title)

AnnotationAssertion(rdfs:label dcterms:title "title")





############################
#   Classes
############################

# Class: co:PMD_0000056 (melting furnace)

EquivalentClasses(co:PMD_0000056 ObjectIntersectionOf(co:PMD_0000655 ObjectSomeValuesFrom(obo:RO_0000085 co:PMD_0000057)))

# Class: co:PMD_0000103 (hardening)

EquivalentClasses(co:PMD_0000103 ObjectIntersectionOf(co:PMD_0000833 ObjectSomeValuesFrom(obo:RO_0000059 hto:HTO_0000002)))
SubClassOf(co:PMD_0000103 ObjectSomeValuesFrom(obo:BFO_0000055 co:PMD_0010013))

# Class: co:PMD_0000655 (furnace)

SubClassOf(co:PMD_0000655 ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000109))
SubClassOf(co:PMD_0000655 ObjectSomeValuesFrom(obo:RO_0000085 co:PMD_0000054))

# Class: co:PMD_0025010 (heating)

AnnotationAssertion(dcterms:source co:PMD_0025010 "DIN EN ISO 4885:2018, §3.109 (thnlrd)")
AnnotationAssertion(rdfs:label co:PMD_0025010 "Erwärmen"@de)
AnnotationAssertion(skos:altLabel co:PMD_0025010 "Aufheizen")
AnnotationAssertion(skos:comment co:PMD_0025010 "Das Erwärmen kann kontinuierlich, nicht kontinuierlich oder allmählich in einem Schritt oder in mehreren Schritten erfolgen."@de)
AnnotationAssertion(skos:comment co:PMD_0025010 "Heating may be continuous, non-continuos or gradually in one or more steps.")
AnnotationAssertion(skos:definition co:PMD_0025010 "Essential heat treatment process where an increase in temperature takes place.")
SubClassOf(co:PMD_0025010 hto:HTO_0000000)

# Class: co:PMD_0025011 (cooling)

AnnotationAssertion(dcterms:source co:PMD_0025011 "DIN EN ISO 4885:2018, §3.45")
AnnotationAssertion(skos:definition co:PMD_0025011 "entweder kontinuierliche, nicht kontinuierliche, stufenweise, allmähliche oder unterbrochene Senkung (oder Behandlung zur Senkung) der Temperatur eines heißen Werkstückes"@de)
SubClassOf(co:PMD_0025011 hto:HTO_0000000)

# Class: hto:HTO_0000000 (heat treatment operation)

AnnotationAssertion(dcterms:source hto:HTO_0000000 "DIN EN ISO 4885:2018, §3 (generic upper-level HT-process taxonomy)")
AnnotationAssertion(dcterms:source hto:HTO_0000000 "DIN EN ISO 4885:2018, §3.167 (Härtung)")
AnnotationAssertion(dcterms:source hto:HTO_0000000 "DIN EN ISO 4885:2018, §3.207 (thermochemische Behandlung)")
AnnotationAssertion(dcterms:source hto:HTO_0000000 "DIN EN ISO 4885:2018, §3.8 (Glühen)")
AnnotationAssertion(rdfs:comment hto:HTO_0000000 "intermediate class/grouping term, not to be instatialized"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000000 "Grundsätzlicher Wärmebehandlungsvorgang"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000000 "heat treatment operation"@en)
AnnotationAssertion(skos:definition hto:HTO_0000000 "Essential processes that make up heat treatments and can be used like building blocks."@en)
SubClassOf(hto:HTO_0000000 obo:COB_0000035)

# Class: hto:HTO_0000001 (quenching function)

AnnotationAssertion(dcterms:source hto:HTO_0000001 "DIN 17022-1:1994, §3.1.2")
AnnotationAssertion(dcterms:source hto:HTO_0000001 "DIN EN ISO 4885:2018, §3.168")
AnnotationAssertion(rdfs:label hto:HTO_0000001 "quenching function"@en)
AnnotationAssertion(skos:definition hto:HTO_0000001 "A quenching function is a (realizable) function that, when realized, enables a system to lower the temparature of a material fast enough, that it hinders diffusion processes and thus produces metastable material states."@en)
AnnotationAssertion(skos:definition hto:HTO_0000001 "Eine Abschreckfunktion ist eine (realisierbare) Funktion, die es einem System ermöglicht die Temperatur eines Material schnell genug abzusenken, sodass Diffusionsprozesse behindert und dadurch metastabile Materialzustände erzeugt werden."@de)
AnnotationAssertion(skos:example hto:HTO_0000001 "The function of a oil bath to quench steel after austenitisation so the material transforms into martensite."@en)
SubClassOf(hto:HTO_0000001 co:PMD_0000055)

# Class: hto:HTO_0000002 (hardening recipe)

AnnotationAssertion(rdfs:label hto:HTO_0000002 "hardening recipe"@en)
SubClassOf(hto:HTO_0000002 co:PMD_0060008)

# Class: hto:HTO_0000003 (temperature change rate specification)

AnnotationAssertion(dcterms:source hto:HTO_0000003 "DIN 17022-1:1994, §3.1.1")
AnnotationAssertion(dcterms:source hto:HTO_0000003 "DIN 17022-1:1994, §5.2.2")
AnnotationAssertion(rdfs:label hto:HTO_0000003 "temperature change rate specification"@en)
AnnotationAssertion(skos:definition hto:HTO_0000003 "A setpoint which - as part of plan specifications (e.g. recipes) - specifies the rate at which temparature is to be changed.")
SubClassOf(hto:HTO_0000003 hto:HTO_0000032)
SubClassOf(hto:HTO_0000003 ObjectSomeValuesFrom(obo:IAO_0000136 hto:HTO_0000005))

# Class: hto:HTO_0000004 (heating recipe)

AnnotationAssertion(dcterms:source hto:HTO_0000004 "DIN 17022-1:1994, §3.1.1")
AnnotationAssertion(rdfs:label hto:HTO_0000004 "heating recipe"@en)
AnnotationAssertion(skos:definition hto:HTO_0000004 "A heat treatment recipe describing the steps and parameters for carrying out a heating process."@en)
AnnotationAssertion(skos:definition hto:HTO_0000004 "Wärmebehandlungsrezept mit dem die Schritte und Parameter zur Durchführung eines Aufheizprozesses beschrieben werden."@de)
SubClassOf(hto:HTO_0000004 co:PMD_0060008)
SubClassOf(hto:HTO_0000004 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000003) ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000006)))

# Class: hto:HTO_0000005 (temperature change rate)

AnnotationAssertion(dcterms:source hto:HTO_0000005 "DIN 17022-1:1994, §3.1.1")
AnnotationAssertion(dcterms:source hto:HTO_0000005 "DIN 17022-1:1994, §5.2.2 (incl. kritische Abkühlgeschwindigkeit K_k)")
AnnotationAssertion(rdfs:label hto:HTO_0000005 "temperature change rate"@en)
AnnotationAssertion(skos:definition hto:HTO_0000005 "A process attribute defining the change of temperature per time unit within a process."@en)
SubClassOf(hto:HTO_0000005 co:PMD_0000008)

# Class: hto:HTO_0000006 (target temperature)

AnnotationAssertion(dcterms:source hto:HTO_0000006 "DIN 17022-1:1994, §5 (generic process-target temperature)")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> hto:HTO_0000006 "target temperature specification"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000006 "target temperature"@en)
AnnotationAssertion(skos:definition hto:HTO_0000006 "A setpoint defining the temperature that is to be reached/held within a process that involves a defined temperature."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000006 "needs work")
SubClassOf(hto:HTO_0000006 hto:HTO_0000032)
SubClassOf(hto:HTO_0000006 ObjectSomeValuesFrom(obo:IAO_0000039 hto:HTO_0000010))
SubClassOf(hto:HTO_0000006 ObjectSomeValuesFrom(obo:IAO_0000136 co:PMD_0000967))
SubClassOf(hto:HTO_0000006 DataSomeValuesFrom(obo:OBI_0002135 xsd:float))

# Class: hto:HTO_0000008 (duration specification)

AnnotationAssertion(dcterms:source hto:HTO_0000008 "DIN 17022-1:1994, Bild 1 (Verweildauer / Erwärm-/Anwärm-/Durchwärm-/Haltedauer)")
AnnotationAssertion(dcterms:source hto:HTO_0000008 "DIN 17022-1:1994, §5.2.1")
AnnotationAssertion(dcterms:source hto:HTO_0000008 "DIN EN ISO 683-2:2018, Tab.11 Fn d, f")
AnnotationAssertion(rdfs:label hto:HTO_0000008 "duration specification"@en)
AnnotationAssertion(skos:definition hto:HTO_0000008 "Device specification as part of a plan specification which specifies the duration of a given process.")
SubClassOf(hto:HTO_0000008 hto:HTO_0000032)
SubClassOf(hto:HTO_0000008 ObjectSomeValuesFrom(obo:IAO_0000136 hto:HTO_0000009))

# Class: hto:HTO_0000009 (duration)

AnnotationAssertion(dcterms:source hto:HTO_0000009 "DIN 17022-1:1994, Bild 1 (Verweildauer/Erwärm-/Anwärm-/Durchwärm-/Haltedauer)")
AnnotationAssertion(dcterms:source hto:HTO_0000009 "DIN EN ISO 683-2:2018, Tab.11 (Anlassdauer / Aust.-dauer)")
AnnotationAssertion(rdfs:label hto:HTO_0000009 "duration"@en)
AnnotationAssertion(skos:definition hto:HTO_0000009 "a temporal interval that describes the temporal extent of a process which is demarcated by the distance of two temporal instants"@en)
SubClassOf(hto:HTO_0000009 obo:BFO_0000202)

# Class: hto:HTO_0000010 (temperature unit)

AnnotationAssertion(dcterms:source hto:HTO_0000010 "DIN EN ISO 4885:2018 (generic, °C usage throughout)")
AnnotationAssertion(rdfs:comment hto:HTO_0000010 "working variable, used for testing only")
AnnotationAssertion(rdfs:label hto:HTO_0000010 "temperature unit"@en)
SubClassOf(hto:HTO_0000010 obo:IAO_0000003)

# Class: hto:HTO_0000011 (austenitizing point)

AnnotationAssertion(dcterms:source hto:HTO_0000011 "DIN 17022-1:1994, §3.1.1")
AnnotationAssertion(dcterms:source hto:HTO_0000011 "DIN EN ISO 4885:2018, §3.14")
AnnotationAssertion(dcterms:source hto:HTO_0000011 "DIN EN ISO 4885:2018, §3.213")
AnnotationAssertion(dcterms:source hto:HTO_0000011 "DIN EN ISO 683-5:2021, Tab.7 col.3")
AnnotationAssertion(rdfs:comment hto:HTO_0000011 "needs more work; austenitic phase can be reached from at least two temperatures for any given material (from liquid or from ferrite)")
AnnotationAssertion(rdfs:label hto:HTO_0000011 "austenitizing point"@en)
AnnotationAssertion(skos:definition hto:HTO_0000011 "A realizable entity of a material which marks the phase change to austenite (γ-iron).")
SubClassOf(hto:HTO_0000011 co:PMD_0020167)

# Class: hto:HTO_0000012 (holding function)

AnnotationAssertion(dcterms:source hto:HTO_0000012 "DIN 17022-1:1994, Bild 1")
AnnotationAssertion(dcterms:source hto:HTO_0000012 "DIN EN ISO 4885:2018, §3.185")
AnnotationAssertion(rdfs:label hto:HTO_0000012 "holding function"@en)
AnnotationAssertion(skos:definition hto:HTO_0000012 "A heat treatment function that, enables a system or device to hold the thermal energy of a material, typically to facilitate diffusion and phase transformation processes within the material."@en)
AnnotationAssertion(skos:example hto:HTO_0000012 "function of a furnace to hold its temperature at a specified temperature")
SubClassOf(hto:HTO_0000012 co:PMD_0000781)

# Class: hto:HTO_0000013 (hardening heat treatment recipe)

AnnotationAssertion(dcterms:source hto:HTO_0000013 "DIN 17022-1:1994, §3.1")
AnnotationAssertion(dcterms:source hto:HTO_0000013 "DIN EN ISO 683-2:2018, Tab.11")
AnnotationAssertion(dcterms:source hto:HTO_0000013 "DIN EN ISO 683-3:2022, Tab.8")
AnnotationAssertion(rdfs:comment hto:HTO_0000013 "add target temperature in axioms, combine it with austenitisation temperature")
AnnotationAssertion(rdfs:label hto:HTO_0000013 "hardening heat treatment recipe"@en)
AnnotationAssertion(skos:definition hto:HTO_0000013 "A heat treatment recipe describing the steps and conditions for carrying out a hardening process."@en)
AnnotationAssertion(skos:definition hto:HTO_0000013 "Wärmebehandlungsrezept mit dem Schritte und Parameter für die Durchführung eines Härtungsprozesses beschrieben werden."@de)
SubClassOf(hto:HTO_0000013 ObjectIntersectionOf(hto:HTO_0000002 ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000004) ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000014) ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000015) ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000016)))

# Class: hto:HTO_0000014 (holding recipe)

AnnotationAssertion(dcterms:source hto:HTO_0000014 "DIN 17022-1:1994, §5.2.1")
AnnotationAssertion(dcterms:source hto:HTO_0000014 "DIN EN ISO 4885:2018, §3.185")
AnnotationAssertion(rdfs:label hto:HTO_0000014 "holding recipe"@en)
AnnotationAssertion(skos:definition hto:HTO_0000014 "A heat treatment recipe outlining the steps and parameters for carrying out a holding process."@en)
AnnotationAssertion(skos:definition hto:HTO_0000014 "Wärmebehandlungsrezept, in dem die Schritte und Parameter zur Durchführung eines Halteprozesses beschrieben werden."@de)
SubClassOf(hto:HTO_0000014 co:PMD_0060008)
SubClassOf(hto:HTO_0000014 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000006) ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000008)))

# Class: hto:HTO_0000015 (soaking recipe)

AnnotationAssertion(dcterms:source hto:HTO_0000015 "DIN 17022-1:1994, Bild 1 (Durchwärmdauer)")
AnnotationAssertion(dcterms:source hto:HTO_0000015 "DIN EN ISO 4885:2018, §3.185")
AnnotationAssertion(rdfs:label hto:HTO_0000015 "soaking recipe"@en)
AnnotationAssertion(skos:definition hto:HTO_0000015 "A heat treatment recipe outlining the steps and parameters for carrying out a soaking process."@en)
AnnotationAssertion(skos:definition hto:HTO_0000015 "Wärmebehandlungsrezept, in dem die Schritte und Parameter zur Durchführung eines Durchwärmprozesses beschrieben werden."@de)
SubClassOf(hto:HTO_0000015 co:PMD_0060008)
SubClassOf(hto:HTO_0000015 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000006) ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000008)))

# Class: hto:HTO_0000016 (quenching recipe)

AnnotationAssertion(dcterms:source hto:HTO_0000016 "DIN 17022-1:1994, §5.2.2")
AnnotationAssertion(dcterms:source hto:HTO_0000016 "DIN EN ISO 4885:2018, §3.168")
AnnotationAssertion(rdfs:label hto:HTO_0000016 "quenching recipe"@en)
