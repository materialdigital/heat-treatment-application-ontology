# Class: hto:HTO_0000022 (Vergüten)

AnnotationAssertion(dcterms:source hto:HTO_0000022 "DIN 17022-1:1994, §3.3")
AnnotationAssertion(dcterms:source hto:HTO_0000022 "DIN EN ISO 4885:2018, §3.169")
AnnotationAssertion(dcterms:source hto:HTO_0000022 "DIN EN ISO 683-2:2018, Tab.1 Zeile 5 (+QT)")
AnnotationAssertion(rdfs:label hto:HTO_0000022 "Vergüten"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000022 "quenching and tempering"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000022 "Abschrecken und Anlassen"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000022 "QT"@en)
AnnotationAssertion(skos:definition hto:HTO_0000022 "Hardening (3.167) of a workpiece, followed by tempering, in order to produce a condition characterised by a good combination of hardness and toughness."@en)
AnnotationAssertion(skos:definition hto:HTO_0000022 "Härtung (3.167) eines Werkstückes mit anschließendem Anlassen, um einen Zustand zu erzeugen, der durch eine gute Kombination von Härte und Zähigkeit gekennzeichnet ist."@de)
SubClassOf(Annotation(obo:IAO_0000116 "this axiom should also include the order of the process (hardening precedes tempering)") hto:HTO_0000022 ObjectIntersectionOf(hto:HTO_0000020 ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000038) ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000040)))
SubClassOf(hto:HTO_0000022 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:BFO_0000117 hto:HTO_0000038) ObjectSomeValuesFrom(obo:BFO_0000117 hto:HTO_0000040) ObjectSomeValuesFrom(obo:BFO_0000117 ObjectIntersectionOf(hto:HTO_0000040 ObjectSomeValuesFrom(obo:BFO_0000063 hto:HTO_0000038)))))

