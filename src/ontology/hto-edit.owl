AnnotationAssertion(rdfs:label hto:HTO_0000108 "Mx transformation temperature"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000108 "Mx-Temperatur"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000108 "M_x"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000108 "Mx"@en)
