                skos:definition "An engine to convert kinetic energy of a gas (movement of air in the atmosphere, wind) into the rotation of a shaft which drives a generator."@en .


###  https://w3id.org/pmd/hto/HTO_0000047
hto:HTO_0000047 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000055 ;
                rdfs:label "water turbine"@en ;
                skos:definition "An engine which converts kinetic energy of water into rotational energy of a shaft connected to a generator."@en .


###  https://w3id.org/pmd/hto/HTO_0000048
hto:HTO_0000048 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000055 ;
                rdfs:label "steam turbine"@en ;
                skos:definition "A machine that extracts thermal energy from pressurized steam and uses it to do mechanical work utilising a rotating output shaft."@en .


###  https://w3id.org/pmd/hto/HTO_0000049
hto:HTO_0000049 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000056 ;
                rdfs:label "turbojet engine"@en ;
                skos:definition "combination of a gas turbine and and a propelling nozzle" .


###  https://w3id.org/pmd/hto/HTO_0000050
hto:HTO_0000050 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000044 ;
                rdfs:label "compressor"@en ;
                skos:definition "A machine that increases the pressure of a gas by reducing its volume."@en .


###  https://w3id.org/pmd/hto/HTO_0000051
hto:HTO_0000051 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000044 ;
                rdfs:label "propeller"@en ;
                skos:definition "A powered machine with a rotating hub and radiating blades which exert linear thrust upon a working fluid such as water or air."@en .


###  https://w3id.org/pmd/hto/HTO_0000052
hto:HTO_0000052 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000044 ;
                rdfs:label "turbopump"@en ;
                skos:definition "A machine powered by a gas engine to create high throughput and high pressure flow of fluid media."@en .


###  https://w3id.org/pmd/hto/HTO_0000053
hto:HTO_0000053 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000044 ;
                rdfs:label "Ventilator"@de ,
                           "fan"@en ;
                skos:definition "A powered machine that creates airflow."@en .


###  https://w3id.org/pmd/hto/HTO_0000054
hto:HTO_0000054 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000044 ;
                rdfs:label "electric generator"@en ;
                skos:definition "A machine that converts mechanical energy to electrical energy."@en .


###  https://w3id.org/pmd/hto/HTO_0000055
hto:HTO_0000055 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000045 ;
                rdfs:label "turbine"@en .


###  https://w3id.org/pmd/hto/HTO_0000056
hto:HTO_0000056 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000045 ;
                rdfs:label "heat engine"@en ;
                skos:definition "A system that transfers thermal energy to do mechanical or electrical work." .


###  https://w3id.org/pmd/hto/HTO_0000057
hto:HTO_0000057 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000045 ;
                rdfs:label "Elektromotor"@de ,
                           "electric motor"@en ;
                skos:definition "An engine which transforms electric energy into mechanical energy."@en .


###  https://w3id.org/pmd/hto/HTO_0000058
hto:HTO_0000058 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000056 ;
                rdfs:label "internal combustion engine"@en ;
                skos:definition "An engine that uses combustion to turn chemical energy into mechanical energy by the transferral of kinetic energy from pressure increase of hot gas expansion into the movement of engine parts." ;
                skos:example """driven parts can be:
pistons (piston engine)
turbine blades (gas turbine)
rotor (Wankel engine)
nozzle (jet engine).""" .


###  https://w3id.org/pmd/hto/HTO_0000059
hto:HTO_0000059 rdf:type owl:Class ;
                rdfs:subClassOf obo:BFO_0000203 ;
                owl:disjointWith hto:HTO_0000060 ;
                dc:source "DIN 17022-1:1994, Bild 1 (process-step start instants, operational usage)" ;
                rdfs:label "start time"@en ;
                skos:definition "A temporal instant that specifies the date(time) a process started." ;
                skos:example "09.06.2022 17:48:47" .


###  https://w3id.org/pmd/hto/HTO_0000060
hto:HTO_0000060 rdf:type owl:Class ;
                rdfs:subClassOf obo:BFO_0000203 ;
                dc:source "DIN 17022-1:1994, Bild 1 (process-step end instants, operational usage)" ;
                rdfs:label "end time"@en ;
                skos:definition "A temporal instant that specifies the date(time) a process ended." ;
                skos:example "09.06.2022 18:18:47" .


###  https://w3id.org/pmd/hto/HTO_0000061
hto:HTO_0000061 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000000 ;
                dc:source "DIN EN ISO 4885:2018, §3.185" ;
                rdfs:comment "Die HoldingTime ist stets mit einer vorhergehende SoakingTime verbunden."@de ;
                rdfs:label "Halten"@de ,
                           "holding"@en ;
                skos:definition """Grundsätzlicher Wärmebehandlungsvorgang ohne Temperaturänderung im Ofen.
Teil einer Zeit-Temperatur-Folge, bei dem die Temperatur konstant gehalten wird"""@de ,
                                "essential heat treatment process step without temperature change in the furnace after the designated temperature was homogeneously reached within the part."@en .


###  https://w3id.org/pmd/hto/HTO_0000062
hto:HTO_0000062 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0025011 ;
                dc:source "DIN EN ISO 4885:2018, §3.168" ;
                rdfs:label "Abschrecken"@de ,
                           "quenching"@en ;
                skos:definition "Grundsätzlicher Wärmebehandlungsvorgang mit stark erhöhter Abkühlgeschwindigkeit, mit dem Ziel der Verhinderung diffusionsgesteuerter Umwandlungen."@de ,
                                "Grundsätzlicher Wärmebehandlungsvorgang, bei dem ein Werkstück mit größerer Geschwindigkeit als an ruhender Luft abgekühlt (3.45) wird."@de ,
                                "essential heat treatment process in which a workpiece is cooled (3.45) at a higher rate than in still air."@en ,
                                "essential heat treatment process with significantly increased cooling rate, aimed at preventing diffusion based transformations."@en .


###  https://w3id.org/pmd/hto/HTO_0000063
hto:HTO_0000063 rdf:type owl:Class ;
                rdfs:subClassOf obo:IAO_0000027 ;
                rdfs:label "counter"@en ;
                skos:definition "A data item that describes the position of an entity within a sequential chain of action with an integer value." ;
                skos:example "Numbering of subprocesses in a heat treatment sequence." .


###  https://w3id.org/pmd/hto/HTO_0000064
hto:HTO_0000064 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000008 ;
                rdfs:label "flow rate"@en ;
                skos:definition "a process attribute quantifying the volume of a continuous substance that traverses a designated spatial boundary per unit of duration."@en .


###  https://w3id.org/pmd/hto/HTO_0000065
hto:HTO_0000065 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000032 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty obo:IAO_0000136 ;
                                  owl:someValuesFrom hto:HTO_0000064
                                ] ;
                dc:source "DIN 17022-4:1998, §7.3 (atmosphere flow control)" ;
                rdfs:label "flow rate specification"@en ;
                skos:definition "Setpoint defining the flow rate of some fluid."@en ,
                                "Sollwert einer Durchflussrate für Fluide."@de .


###  https://w3id.org/pmd/hto/HTO_0000066
hto:HTO_0000066 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000000 ;
                dc:source "DIN 17022-4:1998, §7.3 (Plasmanitrieren — Ofendruck < 10 mbar via evacuation, operational)" ;
                rdfs:label "evacuation"@en ;
                skos:definition "essential heat treatment process that creates a vacuum. Removing atmoshpere and decreasing pressure."@en .


###  https://w3id.org/pmd/hto/HTO_0000067
hto:HTO_0000067 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000781 ;
                dc:source "DIN 17022-4:1998, §7.3" ;
                rdfs:label "evacuation function"@en ;
                skos:definition "A heat treatment function to decrease a volume's pressure to vacuum, removing possibly present gases and fluids."@en .


###  https://w3id.org/pmd/hto/HTO_0000068
hto:HTO_0000068 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0020113 ;
                dc:source "DIN 17022-1:1994, Tab.2" ,
                          "DIN EN ISO 4885:2018, §3.170" ,
                          "DIN EN ISO 683-2:2018, Tab.11 Fn e" ;
                rdfs:label "Abschreckmittel"@de ,
                           "quenchant"@en ;
                skos:editorialNote "needs work" .


###  https://w3id.org/pmd/hto/HTO_0000069
hto:HTO_0000069 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0020114 ;
                rdfs:label "quenchant role"@en ;
                skos:definition "A medium role of a fluid to serve as an intermediary for the transmission of thermal energy from an object to the fluid in a capacity that exeeds the transmission from static air."@en .


###  https://w3id.org/pmd/hto/HTO_0000070
hto:HTO_0000070 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0020114 ;
                rdfs:label "coolant role"@en ;
                skos:definition "A medium role of a fluid to serve as an intermediary for the transmission of thermal energy from an object to the fluid."@en .


###  https://w3id.org/pmd/hto/HTO_0000071
hto:HTO_0000071 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0020113 ;
                rdfs:label "coolant"@en ;
                skos:editorialNote "needs work" .


###  https://w3id.org/pmd/hto/HTO_0000072
hto:HTO_0000072 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000019 ;
                dc:source "DIN EN ISO 4885:2018, §3.37 (Einsatzhärten = Aufkohlen + Härten)" ;
                rdfs:label "Einsatzhärten"@de ,
                           "case hardening"@en ;
                skos:definition "Behandlung bestehend aus Aufkohlen (3.36) oder Carbonitrieren (3.35) mit anschließender Härtung (3.167)."@de ,
                                "Surface hardening process comprised of carburising, hardening and tempering of case hardnening steels."@en ,
                                "Treatment consisting of carburising (3.36) or carbonitriding (3.35) followed by hardening (3.167)."@en ;
                skos:editorialNote "DIN audit (2026-06-09, γ refinement): HTO_0000072 (recently added upstream as case-hardening PROCESS) is overlaid here with DE label 'Einsatzhärten' and verbatim 4885 §3.37 wording. Earlier draft had a twin class hto:HTO_0000106; removed in favour of this overlay to keep upstream IRIs intact (Q2c style). HTO_0000106 slot vacated for Divya to re-claim. The depth measure CHD is the separate HTO_0000089 — do not conflate process with depth."@en .


###  https://w3id.org/pmd/hto/HTO_0000073
hto:HTO_0000073 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0040001 ;
                dc:source "DIN 17022-4:1998, §9.2 (Bild 7; via DIN 50190-3)" ,
                          "DIN EN ISO 4885:2018, §3.73" ,
                          """ISO 18203:2016, §3.4 (acceptance-criterion source — outside DIN corpus)
DIN EN ISO 18203:2022-07 (https://dx.doi.org/10.31030/3344011)""" ;
                rdfs:comment "the defined boundary value usually is set 50 HV above core hardness" ;
                rdfs:label "Nitrierhärtetiefe"@de ,
                           "nitriding hardness depth"@en ;
                skos:altLabel "NHD"@en ,
                              "effective case depth after nitriding"@en ;
                skos:definition "Distance from the surface of a nitrided or nitrocarburised workpiece to the point at which the hardness equals a defined boundary value."@en ,
                                "Senkrechter Abstand von der Oberfläche eines nitrierten oder nitrocarburierten Werkstückes bis zu dem Punkt, an dem die Härte einem Grenzwert entspricht."@de ;
                skos:editorialNote "DIN audit re-IRI (2026-06-09): the legacy class <https://w3id.org/pmd/co/HTO_0000039> was misnamespaced under pmd/co/ (should have been pmd/hto/), and the local ID HTO_0000039 collided with <https://w3id.org/pmd/hto/HTO_0000039> (annealing). Re-IRIed to hto:HTO_0000073 (next free above HTO_0000072 case hardening). owl:equivalentClass preserves A-Box / external compatibility; the legacy IRI is marked owl:deprecated below."@en .


###  https://w3id.org/pmd/hto/HTO_0000074
hto:HTO_0000074 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000019 ;
                dc:source "DIN 17022-4:1998, §4.2" ,
                          "DIN EN ISO 4885:2018, §3.144" ;
                rdfs:label "Nitrocarburieren"@de ,
                           "nitrocarburizing"@en ;
                skos:altLabel "nitrocarburising"@en ;
                skos:definition "Thermochemical treatment (3.207) to produce a hard surface layer containing nitrides and nitrocarbides, forming a compound layer and an underlying diffusion layer."@en ,
                                "Thermochemische Behandlung (3.207) zur Herstellung einer harten Randschicht, die Nitride und Nitrocarbide enthält, zur Bildung einer Verbindungsschicht und einer darunter liegenden Diffusionsschicht."@de ;
                skos:editorialNote "DIN audit re-IRI (2026-06-09): the legacy class <https://w3id.org/pmd/co/HTO_0000063> was misnamespaced under pmd/co/ (should have been pmd/hto/), and the local ID HTO_0000063 collided with <https://w3id.org/pmd/hto/HTO_0000063> (counter). Re-IRIed to hto:HTO_0000074. NB: DIN EN ISO 4885 §3.144 Anm.2 records disjointness with Carbonitrieren (HTO_0000075) — the two are NOT synonyms in DIN despite industry colloquial conflation."@en .


###  https://w3id.org/pmd/hto/HTO_0000075
hto:HTO_0000075 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000019 ;
                dc:source "DIN EN ISO 4885:2018, §3.35" ;
                rdfs:label "Carbonitrieren"@de ,
                           "carbonitriding"@en ;
                skos:definition "Thermochemical treatment (3.207) to enrich the surface layer with carbon and nitrogen; carbonitriding is a carburising process (3.36)."@en ,
                                "Thermochemische Behandlung (3.207), um die Randschicht mit Kohlenstoff und Stickstoff anzureichern; Carbonitrieren ist ein Aufkohlungsprozess (3.36)."@de ;
                skos:editorialNote "DIN audit re-IRI (2026-06-09): the legacy class <https://w3id.org/pmd/co/HTO_0000064> was misnamespaced under pmd/co/ (should have been pmd/hto/), and the local ID HTO_0000064 collided with <https://w3id.org/pmd/hto/HTO_0000064> (flow rate). Re-IRIed to hto:HTO_0000075. NB: §3.144 Anm.2 disjointness with Nitrocarburieren (HTO_0000074)."@en .


###  https://w3id.org/pmd/hto/HTO_0000076
hto:HTO_0000076 rdf:type owl:Class ;
                rdfs:subClassOf obo:BFO_0000145 ;
                dc:source "DIN EN ISO 4885:2018, §3.33" ,
                          "DIN EN ISO 4885:2018, §3.33 Anm.1 (operational vs. thermodynamic contrast)" ;
                rdfs:label "Kohlenstoffpegel"@de ,
                           "carbon level"@en ;
                skos:altLabel "C-Pegel"@de ;
                skos:definition "Relational quality describing the carbon content (mass-fraction in %) that an austenitised pure-iron sample assumes in equilibrium with the carburising agent at a specified temperature."@en ,
                                "Relationale Eigenschaft, die beschreibt, welchen Kohlenstoffgehalt (als Massenanteil in %), den eine austenitisierte Probe aus Reineisen bei bestimmter Temperatur im Gleichgewicht mit dem Aufkohlungsmittel annimmt."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): DIN EN ISO 4885 §3.33 Anm.1 explicitly contrasts 'Kohlenstoffpegel' (operationally defined) with 'Kohlenstoffpotenzial' (thermodynamic) — the two are NOT synonymous. HTO's existing Carbon Potential carries the thermodynamic reading; this new class carries the §3.33 operational definition."@en .


###  https://w3id.org/pmd/hto/HTO_0000077
hto:HTO_0000077 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000857 ;
                dc:source "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)" ,
                          "DIN EN ISO 4885:2018, §3.12" ;
                rdfs:label "Austenit"@de ,
                           "austenite"@en ;
                skos:definition "Microstructure that is a solid solution of one or more elements in γ-iron (3.91)."@en ,
                                "Mikrogefüge, das eine feste Lösung eines oder mehrerer Elemente im γ-Eisen (3.91) ist."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.12 + Tabelle 1. Parent BFO_0000040 (material entity) selected as the closest BFO anchor for a phase as a material-bearer; some HTO maintainers may prefer to re-anchor under a PMDco material-phase class once one is added upstream."@en ,
                                   "All term definitions copied from DIN 4885 should be rid of the internal reference number e.g. \"3.91\" (thnlrd)" .


###  https://w3id.org/pmd/hto/HTO_0000078
hto:HTO_0000078 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000857 ;
                dc:source "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)" ,
                          "DIN EN ISO 4885:2018, §3.137" ;
                rdfs:label "Martensit"@de ,
                           "martensite"@en ;
                skos:definition "Gefüge/Phase (3.156), die in kohlenstoffhaltigen Stählen durch Abkühlen (3.45) des Austenits (3.12) gebildet wird, wobei die hohe Geschwindigkeit des Abkühlens verhindert, dass ausreichend Kohlenstoffatome aus der Kristallstruktur diffundieren können, um Zementit (3.39) (Fe3C) zu bilden."@de ,
                                "Microstructure/phase (3.156) formed in carbon-bearing steels by cooling (3.45) of austenite (3.12), where the high cooling rate prevents sufficient carbon atoms from diffusing out of the crystal structure to form cementite (3.39) (Fe3C)."@en ;
                skos:editorialNote "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.137 + Tabelle 1."@en .


###  https://w3id.org/pmd/hto/HTO_0000079
hto:HTO_0000079 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000857 ;
                dc:source "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)" ,
                          "DIN EN ISO 4885:2018, §3.17" ;
                rdfs:label "Bainit"@de ,
                           "bainite"@en ;
                skos:definition "Microstructure resulting from a transformation of austenite (3.12) at temperatures above the martensite (3.137) start temperature (Ms) and outside the range of pearlite (3.155), consisting of ferrite laths with carbides arranged either within (lower bainite) or between (upper bainite) the ferrite laths."@en ,
                                "Mikrogefüge, das aus einer Umwandlung von Austenit (3.12) resultiert bei Temperaturen über die Starttemperatur (Ms) von Martensit (3.137) und außerhalb des Bereichs von Perlit (3.155), der aus Ferritlatten und Carbiden besteht, die entweder innerhalb der Ferritlatten (untere Bainite) oder zwischen den Ferritlatten angeordnet sind (obere Bainite)."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.17 + Tabelle 1."@en .


###  https://w3id.org/pmd/hto/HTO_0000080
hto:HTO_0000080 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000857 ;
                dc:source "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)" ,
                          "DIN EN ISO 4885:2018, §3.85" ;
                rdfs:label "Ferrit"@de ,
                           "ferrite"@en ;
                skos:definition "Gefüge von Eisen oder Stahl mit kubisch-raumzentrierter Gitterstruktur."@de ,
                                "Microstructure of iron or steel with a body-centred cubic lattice structure."@en ;
                skos:editorialNote "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.85 + Tabelle 1."@en .


###  https://w3id.org/pmd/hto/HTO_0000081
hto:HTO_0000081 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000857 ;
                dc:source "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)" ,
                          "DIN EN ISO 4885:2018, §3.155" ;
                rdfs:label "Perlit"@de ,
                           "pearlite"@en ;
                skos:definition "Aus Ferrit- (3.85) und Zementit- (3.39) Lamellen bestehender Gefügebestandteil, der durch die eutektoidische Austenitumwandlung (3.56) und der gleichzeitig ablaufenden Transformation in Ferrit und Zementit gebildet wird."@de ,
                                "Microstructure constituent consisting of ferrite (3.85) and cementite (3.39) lamellae, formed by the eutectoidic transformation of austenite (3.56) and the concomitant transformation into ferrite and cementite."@en ;
                skos:editorialNote "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.155 + Tabelle 1."@en .


###  https://w3id.org/pmd/hto/HTO_0000082
hto:HTO_0000082 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000857 ;
                dc:source "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)" ,
                          "DIN EN ISO 4885:2018, §3.39" ;
                rdfs:label "Zementit"@de ,
                           "cementite"@en ;
                skos:definition "Microstructure composed of iron carbide with composition Fe3C."@en ,
                                "Mokrogefüge, das das Carbid des Eisens, mit der Zusammensetzung Fe3C ist."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.39 + Tabelle 1."@en .


###  https://w3id.org/pmd/hto/HTO_0000083
hto:HTO_0000083 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0020167 ;
                dc:source "DIN EN ISO 4885:2018, §3.213 Anm.1" ;
                rdfs:label "Martensit-Starttemperatur"@de ,
                           "martensite start temperature"@en ;
                skos:altLabel "M_s"@en ,
                              "Ms"@de ;
                skos:definition "Temperatur, bei der die Umwandlung von Austenit in Martensit (3.137) beim Abkühlen (3.45) beginnt."@de ,
                                "Temperature at which the transformation of austenite into martensite (3.137) begins upon cooling (3.45)."@en ;
                skos:editorialNote "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1 (Bei Stählen können im Wesentlichen folgende Umwandlungstemperaturen unterschieden werden)."@en .


###  https://w3id.org/pmd/hto/HTO_0000084
hto:HTO_0000084 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0020167 ;
                dc:source "DIN EN ISO 4885:2018, §3.213 Anm.1" ;
                rdfs:label "Martensit-Endtemperatur"@de ,
                           "martensite finish temperature"@en ;
                skos:altLabel "M_f"@en ,
                              "Mf"@de ;
                skos:definition "Temperatur, bei der die Umwandlung von Austenit in Martensit beim Abkühlen annähernd vollständig ist."@de ,
                                "Temperature at which the transformation of austenite into martensite is approximately complete upon cooling."@en ;
                skos:editorialNote "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1."@en .


###  https://w3id.org/pmd/hto/HTO_0000085
hto:HTO_0000085 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0020167 ;
                dc:source "DIN EN ISO 4885:2018, §3.213 Anm.1" ;
                rdfs:label "A1 transformation temperature"@en ,
                           "A1-Temperatur"@de ;
                skos:altLabel "A1"@en ,
                              "A_1"@en ;
                skos:definition "Equilibrium temperature defining the lower limit of austenite (3.12) existence."@en ,
                                "Gleichgewichts-Temperatur, die die untere Grenze der Existenz von Austenit (3.12) festlegt."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1."@en .


###  https://w3id.org/pmd/hto/HTO_0000086
hto:HTO_0000086 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0020167 ;
                dc:source "DIN EN ISO 4885:2018, §3.213 Anm.1" ;
                rdfs:label "A3 transformation temperature"@en ,
                           "A3-Temperatur"@de ;
                skos:altLabel "A3"@en ,
                              "A_3"@en ;
                skos:definition "Equilibrium temperature defining the upper limit of ferrite (3.85) existence."@en ,
                                "Gleichgewichts-Temperatur, die die obere Grenze der Existenz von Ferrit (3.85) festlegt."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1."@en .


###  https://w3id.org/pmd/hto/HTO_0000087
hto:HTO_0000087 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0020167 ;
                dc:source "DIN EN ISO 4885:2018, §3.213 Anm.1" ;
                rdfs:label "Am transformation temperature"@en ,
                           "Am-Temperatur"@de ;
                skos:altLabel "A_m"@en ,
                              "Acm"@en ,
                              "Am"@en ;
                skos:definition "Equilibrium temperature defining the upper limit of cementite (3.39) existence in a hypereutectoid steel (3.117)."@en ,
                                "Gleichgewichts-Temperatur, die die obere Grenze der Existenz von Zementit (3.39) in einem übereutektoidischen Stahl (3.117) festlegt."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1. 4885 names this 'Am'; the 'Acm' altLabel is the IIW/ASM-standard naming retained for industry compatibility."@en .


###  https://w3id.org/pmd/hto/HTO_0000088
hto:HTO_0000088 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0040001 ;
                dc:source "DIN EN ISO 4885:2018, §3.74" ,
                          "ISO 18203:2016, §3.5 (modifiziert)" ;
                rdfs:label "Einhärtungstiefe nach Randschichthärten"@de ,
                           "surface hardening depth"@en ;
                skos:altLabel "Randschichthärtungstiefe"@de ,
                              "Rht"@de ,
                              "SHD"@en ;
                skos:definition "Abstand von der Oberfläche bis zu dem Punkt, an dem die Vickers-Härte (HV) 80 % des für die Oberflächenhärte geforderten Mindestwertes für das entsprechende Werkstück beträgt."@de ,
                                "Distance from the surface to the point at which the Vickers hardness (HV) equals 80% of the minimum required surface hardness for the workpiece."@en ;
                skos:editorialNote "DIN audit addition (2026-06-09): surface hardening depth (Rht) from DIN EN ISO 4885 §3.74 (sourced from ISO 18203:2016 §3.5 modified). Distinct from CHD (HTO_0000089) which is the depth measure for Einsatzhärten."@en .


###  https://w3id.org/pmd/hto/HTO_0000089
hto:HTO_0000089 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0040001 ;
                dc:source "DIN EN ISO 4885:2018, §3.72" ,
                          "ISO 18203:2016, §3.1 (modifiziert)" ;
                rdfs:label "Einsatzhärtungstiefe"@de ,
                           "case hardening depth"@en ;
                skos:altLabel "CHD"@en ,
                              "Einsatzhärtungs-Härtetiefe"@de ;
                skos:definition "Abstand von der Oberfläche eines Werkstückes bis zu einem die Dicke der gehärteten (3.167) Schicht festlegenden Punkt."@de ,
                                "Distance from the surface of a workpiece to a point defining the thickness of the hardened (3.167) case."@en ;
                skos:editorialNote "DIN audit addition (2026-06-09): case hardening depth (CHD) from DIN EN ISO 4885 §3.72 (sourced from ISO 18203:2016 §3.1 modified). IMPORTANT: CHD is the depth MEASURE; do NOT confuse with hto:HTO_0000072 'case hardening' which is the PROCESS (Einsatzhärten)."@en .


###  https://w3id.org/pmd/hto/HTO_0000090
hto:HTO_0000090 rdf:type owl:Class ;
                obo:IAO_0100001 hto:HTO_0000088 ;
                rdfs:comment "unnecessary grouping term" ;
                rdfs:label "OBSOLETE Oberflächenhärtungstiefe"@de ,
                           "OBSOLETE surface hardening depth (generic)"@en ;
                owl:deprecated "true"^^xsd:boolean ;
                skos:definition "OBSOLETE Generic depth term for surface hardening; in industrial practice referred to as Surface Hardening Depth (SHD); in DIN normation usually narrowed to Rht (§3.74) or CHD (§3.72)."@en ,
                                "OBSOLETE Generischer Tiefenbegriff für Randschichthärtungen, in der industriellen Praxis als 'Surface Hardening Depth' (SHD) verwendet; nach DIN-Normierung in der Regel präzisiert zu Rht (§3.74) oder CHD (§3.72)."@de .


###  https://w3id.org/pmd/hto/HTO_0000091
hto:HTO_0000091 rdf:type owl:Class ;
                rdfs:subClassOf obo:BFO_0000145 ;
                dc:source "DIN EN ISO 4885:2018, §3.103" ;
                rdfs:label "Härtbarkeit"@de ,
                           "hardenability"@en ;
                skos:definition "Relational quality describing the ability of steels to transform into martensite (3.137) and/or bainite (3.17)."@en ,
                                "Relationale Eigschenschaft, die die Fähigkeit von Stählen beschreibt, zu Martensit (3.137) und/oder Bainit (3.17) umzuwandeln."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): material quality from DIN EN ISO 4885 §3.103. The §3.103 Anm.1 notes that Härtbarkeit is frequently quantified via the Stirnabschreckversuch (HTO_0000092)."@en .


###  https://w3id.org/pmd/hto/HTO_0000092
hto:HTO_0000092 rdf:type owl:Class ;
                rdfs:subClassOf obo:OBI_0000070 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty obo:RO_0009006 ;
                                  owl:someValuesFrom hto:HTO_0000091
                                ] ;
                dc:source "DIN EN ISO 4885:2018, §3.128" ,
                          "ISO 642 (Jominy end-quench test procedure)" ;
                rdfs:label "Jominy end-quench test"@en ,
                           "Stirnabschreckversuch"@de ;
                skos:altLabel "Jominy test"@en ,
                              "Jominy-Versuch"@de ;
                skos:definition "Assay that is a standardised test method for assessing hardenability (3.103)."@en ,
                                "Ein Assay bzw. genormtes Prüfverfahren zur Beurteilung der Härtbarkeit (3.103)."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): test method from DIN EN ISO 4885 §3.128. Reinforcing standards: ISO 642 (test procedure)."@en .


###  https://w3id.org/pmd/hto/HTO_0000093
hto:HTO_0000093 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000039 ;
                dc:source "DIN EN ISO 4885:2018, §3.186" ,
                          "DIN EN ISO 683-2:2018, §7.2 (+A delivery state)" ;
                rdfs:label "Weichglühen"@de ,
                           "soft annealing"@en ;
                skos:definition "Heat treatment (3.108) to reduce the hardness of a ferrous product to a specified level."@en ,
                                "Wärmebehandlung (3.108) zum Vermindern der Härte eines Eisenerzeugnisses auf eine vorgegebene Stufe."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.186. Aligns with DIN EN ISO 683-2 +A delivery state (weichgeglüht)."@en .


###  https://w3id.org/pmd/hto/HTO_0000094
hto:HTO_0000094 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000039 ;
                dc:source "DIN EN ISO 4885:2018, §3.146" ,
                          "DIN EN ISO 683-7:2025, §6.2.1 (+N delivery state)" ;
                rdfs:label "Normalglühen"@de ,
                           "normalizing"@en ;
                skos:definition "Heat treatment (3.108) aimed at refining and homogenising the grain size (3.99) of a ferrous product, consisting of heating (3.109) to a temperature slightly above A3 (A1 for hypereutectoid steels (3.117)), without prolonged soaking, followed by suitable cooling (3.45) to achieve a fine ferrite-pearlite microstructure."@en ,
                                "Wärmebehandlung (3.108) mit dem Ziel, die Korngröße (3.99) eines Eisenerzeugnisses zu verfeinern und schließlich einheitlicher zu machen, bestehend aus Erwärmen (3.109) auf eine Temperatur wenig oberhalb A3 (A1 bei übereutektoidischen Stählen (3.117)), ohne längeres Halten bei dieser Temperatur, und anschließendem zweckmäßigen Abkühlen (3.45) bis zum Erreichen eines feinen ferritisch-perlitischen Gefüges."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.146. Aligns with DIN EN ISO 683-7 +N delivery state."@en .


###  https://w3id.org/pmd/hto/HTO_0000095
hto:HTO_0000095 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000039 ;
                dc:source "DIN EN ISO 4885:2018, §3.197" ,
                          "DIN EN ISO 683-7:2025, §6.2.1 (+SR delivery state)" ;
                rdfs:label "Spannungsarmglühen"@de ,
                           "stress-relief annealing"@en ;
                skos:altLabel "Spannungsarmgluehen"@de ,
                              "stress relieving"@en ;
                skos:definition "Annealing (3.8) at temperatures below A1 to reduce internal stresses without substantially altering the microstructure of a workpiece or ferrous product, followed by slow cooling (3.45)."@en ,
                                "Glühen (3.8) bei Temperaturen unterhalb A1 zur Reduzierung der inneren Spannungen ohne das Gefüge eines Werkstückes oder Eisenerzeugnisses substantiell zu verändern, bis zu einer Stufe auf der die inneren Spannungen verringert werden, mit anschließendem langsamen Abkühlen (3.45)."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.197. Aligns with DIN EN ISO 683-7 +SR delivery state."@en .


###  https://w3id.org/pmd/hto/HTO_0000096
hto:HTO_0000096 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000039 ;
                dc:source "DIN EN ISO 4885:2018, §3.64" ;
                rdfs:label "Diffusionsglühen"@de ,
                           "diffusion annealing"@en ;
                skos:altLabel "homogenization annealing"@en ;
                skos:definition "Heat treatment (3.108) / annealing (3.8) of ferrous products or workpieces to reduce segregation (3.179) and promote homogeneity through diffusion (3.63)."@en ,
                                "Wärmebehandlung (3.108)/Glühen (3.8) von Eisenerzeugnissen oder Werkstücken, um die Seigerung (3.179) zu verringern und die Homogenität durch Diffusion (3.63) zu fördern."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.64."@en .


###  https://w3id.org/pmd/hto/HTO_0000097
hto:HTO_0000097 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000039 ;
                dc:source "DIN EN ISO 4885:2018, §3.29" ;
                rdfs:label "Blankglühen"@de ,
                           "bright annealing"@en ;
                skos:definition "Annealing (3.8) in a medium under conditions that prevent oxidation (3.150) and preserve the original surface quality."@en ,
                                "Glühen (3.8) in einem Mittel unter solchen Bedingungen, dass eine Oxidation (3.150) verhindert wird und die ursprüngliche Oberflächenqualität beibehalten wird."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.29."@en .


###  https://w3id.org/pmd/hto/HTO_0000098
hto:HTO_0000098 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000039 ;
                dc:source "DIN EN ISO 4885:2018, §3.174" ;
                rdfs:label "Rekristallisationsglühen"@de ,
                           "recrystallization annealing"@en ;
                skos:altLabel "recrystallisation annealing"@en ;
                skos:definition "Annealing (3.8) to eliminate the strength increase from cold deformation and to renew grains via nucleation without phase change (3.156)."@en ,
                                "Glühen (3.8) zur Beseitigung der Festigkeitszunahme nach Kaltumformung und Kornneubildung durch Keimbildung ohne Änderung der Phase (3.156)."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.174."@en .


###  https://w3id.org/pmd/hto/HTO_0000099
hto:HTO_0000099 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000039 ;
                dc:source "DIN EN ISO 4885:2018, §3.122" ;
                rdfs:label "inter-critical annealing"@en ,
                           "zwischenkritisches Glühen"@de ;
                skos:altLabel "zwischenkritische Behandlung"@de ;
                skos:definition "Annealing (3.8) of a hypoeutectoid steel (3.118), consisting of heating (3.109) and soaking at temperatures between A1 and A3 to partially produce austenit, followed by suitable cooling (3.45) tailored to the required properties."@en ,
                                "Glühen (3.8) eines untereutektoidischen Stahls (3.118), bestehend aus Erwärmen (3.109) und Halten auf Temperaturen zwischen A1 und A3, um teilweise Austenit zu erzeugen, und anschließendem zweckentsprechenden Abkühlen (3.45), angepasst an die geforderten Eigenschaften."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.122."@en .


###  https://w3id.org/pmd/hto/HTO_0000100
hto:HTO_0000100 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000039 ;
                dc:source "DIN EN ISO 4885:2018, §3.127" ,
                          "DIN EN ISO 4885:2018, §3.8 Anm.1" ;
                rdfs:label "isothermal transformation"@en ,
                           "isothermes Umwandeln"@de ;
                skos:altLabel "isothermal annealing"@en ;
                skos:definition "Heat treatment (3.108) with austenitising (3.14), interrupted cooling (3.45), and isothermal hold at a specified temperature until transformation is complete."@en ,
                                "Wärmebehandlung (3.108) mit Austenitisieren (3.14) und unterbrochenem Abkühlen (3.45) und Konstanthaltung auf eine bestimmte Temperatur bis zur vollständigen Umwandlung."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.127. NB: 4885 §3.8 Anm.1 lists 'isothermes Umwandeln' as one of the named Glühen children."@en .


###  https://w3id.org/pmd/hto/HTO_0000101
hto:HTO_0000101 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000039 ;
                dc:source "DIN EN ISO 4885:2018, §3.188" ;
                rdfs:label "Lösungsglühen"@de ,
                           "solution annealing"@en ;
                skos:altLabel "Lösungsbehandeln"@de ,
                              "solution treating"@en ;
                skos:definition "Heat treatment (3.108) consisting of austenitising (3.14) at a high temperature followed by sufficiently rapid cooling (3.45) to prevent new precipitation upon return to ambient temperature."@en ,
                                "Wärmebehandlung (3.108), bestehend aus Austenitisieren (3.14) auf eine hohe Temperatur mit anschließendem ausreichendem schnellen Abkühlen (3.45), um neue Ausscheidungen nach der Rückkehr zur Umgebungstemperatur zu verhindern."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.188."@en .


###  https://w3id.org/pmd/hto/HTO_0000102
hto:HTO_0000102 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000039 ;
                dc:source "DIN EN ISO 4885:2018, §3.8 Anm.1" ,
                          "DIN EN ISO 4885:2018, §3.89" ;
                rdfs:label "full annealing"@en ,
                           "vollständiges Glühen"@de ;
                skos:altLabel "kritisches Glühen"@de ;
                skos:definition "Annealing (3.8) to achieve a spheroidal microstructure (see 3.190), which involves complete austenitisation (3.14) to a temperature above A3 (for hypoeutectoid steels) or above A1 (for hypereutectoid steels), followed by slow cooling (3.45), to achieve a microstructure close to thermodynamic equilibrium."@en ,
                                "Glühen (3.8) zur Erzielung von kugeligem Gefüge (siehe 3.190), was ein vollständiges Austenitisieren (3.14) auf eine Temperatur oberhalb von A3 (bei hypoeutektoiden Stählen) bzw. oberhalb von A1 (bei hypereutektoiden Stählen) beinhaltet, gefolgt von einer langsamen Abkühlung (3.45), um eine Mikrostruktur zu erzielen, die dem thermodynamischen Gleichgewicht nahekommt."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.89 (Full annealing — listed inline in §3.8 Anm.1 as a named Glühen child). Definition is paraphrased per 4885 conventions; the §3.89 verbatim entry uses generic 'Wärmebehandlung'."@en ,
                                   "deviating from the standard here because 'full annealing' ist supposed to fully transform the microstructure into austenite (hence the name) whereas comparable annealing procedures do not fully transform the material even though they are within the same T-range (normalizing, intercritical annealing). Additional info and explanation provided by TWaldenmaier. (thnlrd)" .


###  https://w3id.org/pmd/hto/HTO_0000103
hto:HTO_0000103 rdf:type owl:Class ;
                owl:equivalentClass hto:HTO_0000104 ;
                rdfs:subClassOf co:PMD_0000779 ;
                dc:source "DIN EN ISO 4885:2018, §3.11" ;
                rdfs:label "Austempern"@de ,
                           "austempering"@en ;
                skos:comment "In practical use, the terms bainitising and austempering are used interchangeably cheifly in US-american english. (thnlrd)"@en ;
                skos:definition "Isothermal heat treatment to produce a bainitic (cf. 3.17, 3.18) or ausferritic (cf. 3.9) microstructure in a workpiece."@en ,
                                "Isotherme Wärmebehandlung zur Herstellung eines bainitischen (siehe 3.17 und 3.18) oder ausferritischen (siehe 3.9) Gefüges eines Werkstückes."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): isothermal-treatment process from DIN EN ISO 4885 §3.11. Closely related to Bainitisieren (HTO_0000104, §3.18)."@en .


###  https://w3id.org/pmd/hto/HTO_0000104
hto:HTO_0000104 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000779 ;
                dc:source "DIN EN ISO 4885:2018, §3.18" ;
                rdfs:label "Bainitisieren"@de ,
                           "bainitising"@en ;
                skos:comment "In practical use, the terms bainitising and austempering are used interchangeably cheifly in US-american english. (thnlrd)"@en ;
                skos:definition "Austenitisieren (3.14) und Abschrecken (3.168) auf eine Temperatur oberhalb Ms und isothermes Halten auf dieser Temperatur, um sicherzustellen, dass sich der Austenit (3.12) in Bainit (3.17) umwandelt."@de ,
                                "Austenitising (3.14) and quenching (3.168) to a temperature above Ms followed by isothermal hold at that temperature so that austenite (3.12) transforms into bainite (3.17)."@en ;
                skos:editorialNote "DIN audit addition (2026-06-09): process from DIN EN ISO 4885 §3.18."@en .


###  https://w3id.org/pmd/hto/HTO_0000105
hto:HTO_0000105 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0000779 ;
                dc:source "DIN EN ISO 4885:2018, §3.154" ;
                rdfs:label "Patentieren"@de ,
                           "patenting"@en ;
                skos:definition "Heat treatment (3.108) consisting of austenitising (3.14) followed by suitable cooling (3.45) to produce a microstructure favourable for subsequent drawing or roll-drawing of wire or strip."@en ,
                                "Wärmebehandlung (3.108), bestehend aus Austenitisieren (3.14) und anschließendem geeigneten Abkühlen (3.45), um ein für das nachfolgende Ziehen oder Ziehwalzen von Draht oder Band günstiges Gefüge zu erreichen."@de ;
                skos:editorialNote "DIN audit addition (2026-06-09): process from DIN EN ISO 4885 §3.154."@en .


###  https://w3id.org/pmd/hto/HTO_0000107
hto:HTO_0000107 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000040 ;
                dc:source "DIN EN ISO 4885:2018, §3.184" ;
                rdfs:label "Einfachhärten"@de ,
                           "single hardening"@en ;
                skos:definition "In einem Schritt durchgeführtes Härten nach vorausgegangenem Aufkohlen (3.36) und langsamem Abkühlen (3.45) auf Raumtemperatur."@de ,
                                "Single-step hardening following prior carburising (3.36) and slow cooling (3.45) to room temperature."@en ;
                skos:editorialNote "DIN audit addition (2026-06-09): hardening sub-process from DIN EN ISO 4885 §3.184 (siehe Bild 1 b)."@en .


###  https://w3id.org/pmd/hto/HTO_0000108
hto:HTO_0000108 rdf:type owl:Class ;
                rdfs:subClassOf co:PMD_0020167 ;
                dc:source "DIN EN ISO 4885:2018, §3.213 Anm.1" ;
                rdfs:label "Mx transformation temperature"@en ,
                           "Mx-Temperatur"@de ;
                skos:altLabel "M_x"@en ,
                              "Mx"@en ;
                skos:definition "Temperatur, bei der beim Abkühlen x % Volumenanteil Austenit in Martensit umgewandelt wurden."@de ,
                                "Temperature at which, upon cooling, x % volume fraction of austenite has transformed into martensite."@en ;
                skos:editorialNote "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1 (parametric x ∈ (0,100))."@en .


###  https://w3id.org/pmd/hto/HTO_0000109
hto:HTO_0000109 rdf:type owl:Class ;
                rdfs:subClassOf obo:BFO_0000024 ;
                obo:IAO_0000114 "needs work" ;
                dc:source "DIN 17022-1:1994, §7 (generic multi-chamber furnace construction)" ;
                rdfs:comment "unklare Zuordnung innerhalb der SDCs. Eine Kammer existiert nur als Teil eines Gerätes (Device), könnte aber selbst noch einmal als independent continuant definiert werden, da sich in der Kammer Chargen, Gestelle, Thermoelemente etc. befinden."@de ,
                             "moved to fiat object part. correct if every furnace has a chamber" ;
                rdfs:isDefinedBy hto: ;
                rdfs:label "chamber"@en ;
                skos:definition "Systemboundary of a distinct Heattreatment Process. Includes a fluid that has the role of medium role (e.g., Helium or Vacuum)."@en .


###  https://w3id.org/pmd/hto/HTO_0000110
hto:HTO_0000110 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000109 ;
                dc:source "DIN 17022-1:1994, §7 (Ofen-Konstruktion)" ,
                          "DIN 17022-4:1998, §10" ;
                rdfs:isDefinedBy hto: ;
                rdfs:label "Heizkammer"@de ,
                           "heating chamber"@en ;
                skos:definition "Distinguishable chamber of a heat treatment furnace with a heater."@en ,
                                "Ofenkammer mit einer Heizung"@de .


###  https://w3id.org/pmd/hto/HTO_0000111
hto:HTO_0000111 rdf:type owl:Class ;
                rdfs:subClassOf hto:HTO_0000109 ;
                dc:source "DIN 17022-1:1994, §7.2 (Abschreckeinrichtung)" ,
                          "DIN 17022-4:1998, §10.3 (Fassungsverhältnis ≥ 6× Chargengewicht)" ;
                rdfs:isDefinedBy hto: ;
                rdfs:label "Abschreckkammer"@de ,
                           "quenching chamber"@en ;
                skos:definition "Chamber of a heat treatment furnace that is designed to quench objects."@en ,
                                "Kammer eines Wärmebehandlungsofens, die zum Abschrecken von Gegenständen bestimmt ist."@de .


###  https://w3id.org/pmd/hto/HTO_0000112
hto:HTO_0000112 rdf:type owl:Class ;
                rdfs:subClassOf obo:BFO_0000145 ;
                dc:source "DIN EN ISO 4885:2018, §3.33 (Kohlenstoffpegel — contrast Anm.1)" ,
                          "DIN EN ISO 683-3:2022, §A.4 (carburising atmosphere control)" ;
                rdfs:comment "Nitrocarburieren mit Kohlenstoffträger, aus Messwerten abgeleitet KC"@de ,
                             "See standard DIN 1310"@en ;
                rdfs:isDefinedBy hto: ;
                rdfs:label "Kohlenstoffpotential"@de ,
                           "carbon potential"@en ;
                skos:definition "Carbon content of a specimen of pure iron in equilibrium with a carbourizing medium under specific conditions."@en ;
                skos:editorialNote "DIN audit (2026-06-09): DIN EN ISO 4885 §3.33 names the operational quantity 'Kohlenstoffpegel' (carbon level), with §3.33 Anm.1 contrasting it explicitly with the 'thermodynamisches Kohlenstoffpotenzial'. 4885 treats the two as NOT synonymous. hto:CarbonPotential is retained as the thermodynamic-potential quality; the new sibling hto:HTO_0000076 (CarbonLevel) carries the §3.33 operational definition. See hto:HTO_0000076 below for the sibling class."@en .


