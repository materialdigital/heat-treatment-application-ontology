# Class: hto:HTO_0000072 (case hardening)

AnnotationAssertion(obo:IAO_0000116 hto:HTO_0000072 "this is really not connected to the phenomenon of case hardening found in mangos"@en)
AnnotationAssertion(dcterms:source hto:HTO_0000072 "DIN EN ISO 4885:2018, §3.37 (Einsatzhärten = Aufkohlen + Härten)")
AnnotationAssertion(rdfs:label hto:HTO_0000072 "Einsatzhärten"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000072 "case hardening"@en)
AnnotationAssertion(skos:definition hto:HTO_0000072 "Behandlung bestehend aus Aufkohlen (3.36) oder Carbonitrieren (3.35) mit anschließender Härtung (3.167)."@de)
AnnotationAssertion(skos:definition hto:HTO_0000072 "Surface hardening process comprised of carburising, hardening and tempering of case hardnening steels."@en)
AnnotationAssertion(skos:definition hto:HTO_0000072 "Treatment consisting of carburising (3.36) or carbonitriding (3.35) followed by hardening (3.167)."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000072 "DIN audit (2026-06-09, γ refinement): HTO_0000072 (recently added upstream as case-hardening PROCESS) is overlaid here with DE label 'Einsatzhärten' and verbatim 4885 §3.37 wording. Earlier draft had a twin class hto:HTO_0000106; removed in favour of this overlay to keep upstream IRIs intact (Q2c style). HTO_0000106 slot vacated for Divya to re-claim. The depth measure CHD is the separate HTO_0000089 — do not conflate process with depth."@en)
SubClassOf(hto:HTO_0000072 hto:HTO_0000019)

# Class: hto:HTO_0000073 (nitriding hardness depth)

AnnotationAssertion(dcterms:source hto:HTO_0000073 "DIN 17022-4:1998, §9.2 (Bild 7; via DIN 50190-3)")
AnnotationAssertion(dcterms:source hto:HTO_0000073 "DIN EN ISO 4885:2018, §3.73")
AnnotationAssertion(dcterms:source hto:HTO_0000073 "ISO 18203:2016, §3.4 (acceptance-criterion source — outside DIN corpus)
DIN EN ISO 18203:2022-07 (https://dx.doi.org/10.31030/3344011)")
AnnotationAssertion(rdfs:comment hto:HTO_0000073 "the defined boundary value usually is set 50 HV above core hardness")
AnnotationAssertion(rdfs:label hto:HTO_0000073 "Nitrierhärtetiefe"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000073 "nitriding hardness depth"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000073 "NHD"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000073 "effective case depth after nitriding"@en)
AnnotationAssertion(skos:definition hto:HTO_0000073 "Distance from the surface of a nitrided or nitrocarburised workpiece to the point at which the hardness equals a defined boundary value."@en)
AnnotationAssertion(skos:definition hto:HTO_0000073 "Senkrechter Abstand von der Oberfläche eines nitrierten oder nitrocarburierten Werkstückes bis zu dem Punkt, an dem die Härte einem Grenzwert entspricht."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000073 "DIN audit re-IRI (2026-06-09): the legacy class <https://w3id.org/pmd/co/HTO_0000039> was misnamespaced under pmd/co/ (should have been pmd/hto/), and the local ID HTO_0000039 collided with <https://w3id.org/pmd/hto/HTO_0000039> (annealing). Re-IRIed to hto:HTO_0000073 (next free above HTO_0000072 case hardening). owl:equivalentClass preserves A-Box / external compatibility; the legacy IRI is marked owl:deprecated below."@en)
SubClassOf(hto:HTO_0000073 co:PMD_0040001)

# Class: hto:HTO_0000074 (Nitrocarburieren)

AnnotationAssertion(dcterms:source hto:HTO_0000074 "DIN 17022-4:1998, §4.2")
AnnotationAssertion(dcterms:source hto:HTO_0000074 "DIN EN ISO 4885:2018, §3.144")
AnnotationAssertion(rdfs:label hto:HTO_0000074 "Nitrocarburieren"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000074 "nitrocarburizing"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000074 "nitrocarburising"@en)
AnnotationAssertion(skos:definition hto:HTO_0000074 "Thermochemical treatment (3.207) to produce a hard surface layer containing nitrides and nitrocarbides, forming a compound layer and an underlying diffusion layer."@en)
AnnotationAssertion(skos:definition hto:HTO_0000074 "Thermochemische Behandlung (3.207) zur Herstellung einer harten Randschicht, die Nitride und Nitrocarbide enthält, zur Bildung einer Verbindungsschicht und einer darunter liegenden Diffusionsschicht."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000074 "DIN audit re-IRI (2026-06-09): the legacy class <https://w3id.org/pmd/co/HTO_0000063> was misnamespaced under pmd/co/ (should have been pmd/hto/), and the local ID HTO_0000063 collided with <https://w3id.org/pmd/hto/HTO_0000063> (counter). Re-IRIed to hto:HTO_0000074. NB: DIN EN ISO 4885 §3.144 Anm.2 records disjointness with Carbonitrieren (HTO_0000075) — the two are NOT synonyms in DIN despite industry colloquial conflation."@en)
SubClassOf(hto:HTO_0000074 co:PMD_0000779)

# Class: hto:HTO_0000075 (Carbonitrieren)

AnnotationAssertion(dcterms:source hto:HTO_0000075 "DIN EN ISO 4885:2018, §3.35")
AnnotationAssertion(rdfs:label hto:HTO_0000075 "Carbonitrieren"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000075 "carbonitriding"@en)
AnnotationAssertion(skos:definition hto:HTO_0000075 "Thermochemical treatment (3.207) to enrich the surface layer with carbon and nitrogen; carbonitriding is a carburising process (3.36)."@en)
AnnotationAssertion(skos:definition hto:HTO_0000075 "Thermochemische Behandlung (3.207), um die Randschicht mit Kohlenstoff und Stickstoff anzureichern; Carbonitrieren ist ein Aufkohlungsprozess (3.36)."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000075 "DIN audit re-IRI (2026-06-09): the legacy class <https://w3id.org/pmd/co/HTO_0000064> was misnamespaced under pmd/co/ (should have been pmd/hto/), and the local ID HTO_0000064 collided with <https://w3id.org/pmd/hto/HTO_0000064> (flow rate). Re-IRIed to hto:HTO_0000075. NB: §3.144 Anm.2 disjointness with Nitrocarburieren (HTO_0000074)."@en)
SubClassOf(hto:HTO_0000075 co:PMD_0000779)

# Class: hto:HTO_0000076 (carbon level)

AnnotationAssertion(dcterms:source hto:HTO_0000076 "DIN EN ISO 4885:2018, §3.33")
AnnotationAssertion(dcterms:source hto:HTO_0000076 "DIN EN ISO 4885:2018, §3.33 Anm.1 (operational vs. thermodynamic contrast)")
AnnotationAssertion(rdfs:label hto:HTO_0000076 "Kohlenstoffpegel"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000076 "carbon level"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000076 "C-Pegel"@de)
AnnotationAssertion(skos:definition hto:HTO_0000076 "Relational quality describing the carbon content (mass-fraction in %) that an austenitised pure-iron sample assumes in equilibrium with the carburising agent at a specified temperature."@en)
AnnotationAssertion(skos:definition hto:HTO_0000076 "Relationale Eigenschaft, die beschreibt, welchen Kohlenstoffgehalt (als Massenanteil in %), den eine austenitisierte Probe aus Reineisen bei bestimmter Temperatur im Gleichgewicht mit dem Aufkohlungsmittel annimmt."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000076 "DIN audit addition (2026-06-09): DIN EN ISO 4885 §3.33 Anm.1 explicitly contrasts 'Kohlenstoffpegel' (operationally defined) with 'Kohlenstoffpotenzial' (thermodynamic) — the two are NOT synonymous. HTO's existing Carbon Potential carries the thermodynamic reading; this new class carries the §3.33 operational definition."@en)
SubClassOf(hto:HTO_0000076 obo:BFO_0000145)

