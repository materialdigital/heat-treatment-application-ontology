# Class: hto:HTO_0000072 (case hardening)

AnnotationAssertion(dc:source hto:HTO_0000072 "DIN EN ISO 4885:2018, §3.37 (Einsatzhärten = Aufkohlen + Härten)")
AnnotationAssertion(rdfs:label hto:HTO_0000072 "Einsatzhärten"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000072 "case hardening"@en)
AnnotationAssertion(skos:definition hto:HTO_0000072 "Behandlung bestehend aus Aufkohlen (3.36) oder Carbonitrieren (3.35) mit anschließender Härtung (3.167)."@de)
AnnotationAssertion(skos:definition hto:HTO_0000072 "Surface hardening process comprised of carburising, hardening and tempering of case hardnening steels."@en)
AnnotationAssertion(skos:definition hto:HTO_0000072 "Treatment consisting of carburising (3.36) or carbonitriding (3.35) followed by hardening (3.167)."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000072 "DIN audit (2026-06-09, γ refinement): HTO_0000072 (recently added upstream as case-hardening PROCESS) is overlaid here with DE label 'Einsatzhärten' and verbatim 4885 §3.37 wording. Earlier draft had a twin class hto:HTO_0000106; removed in favour of this overlay to keep upstream IRIs intact (Q2c style). HTO_0000106 slot vacated for Divya to re-claim. The depth measure CHD is the separate HTO_0000089 — do not conflate process with depth."@en)
SubClassOf(hto:HTO_0000072 hto:HTO_0000019)

# Class: hto:HTO_0000073 (nitriding hardness depth)

AnnotationAssertion(dc:source hto:HTO_0000073 "DIN 17022-4:1998, §9.2 (Bild 7; via DIN 50190-3)")
AnnotationAssertion(dc:source hto:HTO_0000073 "DIN EN ISO 4885:2018, §3.73")
AnnotationAssertion(dc:source hto:HTO_0000073 "ISO 18203:2016, §3.4 (acceptance-criterion source — outside DIN corpus)
DIN EN ISO 18203:2022-07 (https://dx.doi.org/10.31030/3344011)")
AnnotationAssertion(rdfs:comment hto:HTO_0000073 "the defined boundary value usually is set 50 HV above core hardness")
AnnotationAssertion(rdfs:label hto:HTO_0000073 "Nitrierhärtetiefe"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000073 "nitriding hardness depth"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000073 "NHD"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000073 "effective case depth after nitriding"@en)
AnnotationAssertion(skos:definition hto:HTO_0000073 "Distance from the surface of a nitrided or nitrocarburised workpiece to the point at which the hardness equals a defined boundary value."@en)
AnnotationAssertion(skos:definition hto:HTO_0000073 "Senkrechter Abstand von der Oberfläche eines nitrierten oder nitrocarburierten Werkstückes bis zu dem Punkt, an dem die Härte einem Grenzwert entspricht."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000073 "DIN audit re-IRI (2026-06-09): the legacy class <https://w3id.org/pmd/co/HTO_0000039> was misnamespaced under pmd/co/ (should have been pmd/hto/), and the local ID HTO_0000039 collided with <https://w3id.org/pmd/hto/HTO_0000039> (annealing). Re-IRIed to hto:HTO_0000073 (next free above HTO_0000072 case hardening). owl:equivalentClass preserves A-Box / external compatibility; the legacy IRI is marked owl:deprecated below."@en)
SubClassOf(hto:HTO_0000073 co:PMD_0040001)

# Class: hto:HTO_0000074 (Nitrocarburieren)

AnnotationAssertion(dc:source hto:HTO_0000074 "DIN 17022-4:1998, §4.2")
AnnotationAssertion(dc:source hto:HTO_0000074 "DIN EN ISO 4885:2018, §3.144")
AnnotationAssertion(rdfs:label hto:HTO_0000074 "Nitrocarburieren"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000074 "nitrocarburizing"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000074 "nitrocarburising"@en)
AnnotationAssertion(skos:definition hto:HTO_0000074 "Thermochemical treatment (3.207) to produce a hard surface layer containing nitrides and nitrocarbides, forming a compound layer and an underlying diffusion layer."@en)
AnnotationAssertion(skos:definition hto:HTO_0000074 "Thermochemische Behandlung (3.207) zur Herstellung einer harten Randschicht, die Nitride und Nitrocarbide enthält, zur Bildung einer Verbindungsschicht und einer darunter liegenden Diffusionsschicht."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000074 "DIN audit re-IRI (2026-06-09): the legacy class <https://w3id.org/pmd/co/HTO_0000063> was misnamespaced under pmd/co/ (should have been pmd/hto/), and the local ID HTO_0000063 collided with <https://w3id.org/pmd/hto/HTO_0000063> (counter). Re-IRIed to hto:HTO_0000074. NB: DIN EN ISO 4885 §3.144 Anm.2 records disjointness with Carbonitrieren (HTO_0000075) — the two are NOT synonyms in DIN despite industry colloquial conflation."@en)
SubClassOf(hto:HTO_0000074 hto:HTO_0000019)

# Class: hto:HTO_0000075 (Carbonitrieren)

AnnotationAssertion(dc:source hto:HTO_0000075 "DIN EN ISO 4885:2018, §3.35")
AnnotationAssertion(rdfs:label hto:HTO_0000075 "Carbonitrieren"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000075 "carbonitriding"@en)
AnnotationAssertion(skos:definition hto:HTO_0000075 "Thermochemical treatment (3.207) to enrich the surface layer with carbon and nitrogen; carbonitriding is a carburising process (3.36)."@en)
AnnotationAssertion(skos:definition hto:HTO_0000075 "Thermochemische Behandlung (3.207), um die Randschicht mit Kohlenstoff und Stickstoff anzureichern; Carbonitrieren ist ein Aufkohlungsprozess (3.36)."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000075 "DIN audit re-IRI (2026-06-09): the legacy class <https://w3id.org/pmd/co/HTO_0000064> was misnamespaced under pmd/co/ (should have been pmd/hto/), and the local ID HTO_0000064 collided with <https://w3id.org/pmd/hto/HTO_0000064> (flow rate). Re-IRIed to hto:HTO_0000075. NB: §3.144 Anm.2 disjointness with Nitrocarburieren (HTO_0000074)."@en)
SubClassOf(hto:HTO_0000075 hto:HTO_0000019)

# Class: hto:HTO_0000076 (carbon level)

AnnotationAssertion(dc:source hto:HTO_0000076 "DIN EN ISO 4885:2018, §3.33")
AnnotationAssertion(dc:source hto:HTO_0000076 "DIN EN ISO 4885:2018, §3.33 Anm.1 (operational vs. thermodynamic contrast)")
AnnotationAssertion(rdfs:label hto:HTO_0000076 "Kohlenstoffpegel"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000076 "carbon level"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000076 "C-Pegel"@de)
AnnotationAssertion(skos:definition hto:HTO_0000076 "Relational quality describing the carbon content (mass-fraction in %) that an austenitised pure-iron sample assumes in equilibrium with the carburising agent at a specified temperature."@en)
AnnotationAssertion(skos:definition hto:HTO_0000076 "Relationale Eigenschaft, die beschreibt, welchen Kohlenstoffgehalt (als Massenanteil in %), den eine austenitisierte Probe aus Reineisen bei bestimmter Temperatur im Gleichgewicht mit dem Aufkohlungsmittel annimmt."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000076 "DIN audit addition (2026-06-09): DIN EN ISO 4885 §3.33 Anm.1 explicitly contrasts 'Kohlenstoffpegel' (operationally defined) with 'Kohlenstoffpotenzial' (thermodynamic) — the two are NOT synonymous. HTO's existing Carbon Potential carries the thermodynamic reading; this new class carries the §3.33 operational definition."@en)
SubClassOf(hto:HTO_0000076 obo:BFO_0000145)

# Class: hto:HTO_0000077 (austenite)

AnnotationAssertion(dc:source hto:HTO_0000077 "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)")
AnnotationAssertion(dc:source hto:HTO_0000077 "DIN EN ISO 4885:2018, §3.12")
AnnotationAssertion(rdfs:label hto:HTO_0000077 "Austenit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000077 "austenite"@en)
AnnotationAssertion(skos:definition hto:HTO_0000077 "Microstructure that is a solid solution of one or more elements in γ-iron (3.91)."@en)
AnnotationAssertion(skos:definition hto:HTO_0000077 "Mikrogefüge, das eine feste Lösung eines oder mehrerer Elemente im γ-Eisen (3.91) ist."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000077 "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.12 + Tabelle 1. Parent BFO_0000040 (material entity) selected as the closest BFO anchor for a phase as a material-bearer; some HTO maintainers may prefer to re-anchor under a PMDco material-phase class once one is added upstream."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000077 "All term definitions copied from DIN 4885 should be rid of the internal reference number e.g. \"3.91\" (thnlrd)")
SubClassOf(hto:HTO_0000077 co:PMD_0000857)

# Class: hto:HTO_0000078 (Martensit)

AnnotationAssertion(dc:source hto:HTO_0000078 "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)")
AnnotationAssertion(dc:source hto:HTO_0000078 "DIN EN ISO 4885:2018, §3.137")
AnnotationAssertion(rdfs:label hto:HTO_0000078 "Martensit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000078 "martensite"@en)
AnnotationAssertion(skos:definition hto:HTO_0000078 "Gefüge/Phase (3.156), die in kohlenstoffhaltigen Stählen durch Abkühlen (3.45) des Austenits (3.12) gebildet wird, wobei die hohe Geschwindigkeit des Abkühlens verhindert, dass ausreichend Kohlenstoffatome aus der Kristallstruktur diffundieren können, um Zementit (3.39) (Fe3C) zu bilden."@de)
AnnotationAssertion(skos:definition hto:HTO_0000078 "Microstructure/phase (3.156) formed in carbon-bearing steels by cooling (3.45) of austenite (3.12), where the high cooling rate prevents sufficient carbon atoms from diffusing out of the crystal structure to form cementite (3.39) (Fe3C)."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000078 "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.137 + Tabelle 1."@en)
SubClassOf(hto:HTO_0000078 co:PMD_0000857)

# Class: hto:HTO_0000079 (Bainit)

AnnotationAssertion(dc:source hto:HTO_0000079 "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)")
AnnotationAssertion(dc:source hto:HTO_0000079 "DIN EN ISO 4885:2018, §3.17")
AnnotationAssertion(rdfs:label hto:HTO_0000079 "Bainit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000079 "bainite"@en)
AnnotationAssertion(skos:definition hto:HTO_0000079 "Microstructure resulting from a transformation of austenite (3.12) at temperatures above the martensite (3.137) start temperature (Ms) and outside the range of pearlite (3.155), consisting of ferrite laths with carbides arranged either within (lower bainite) or between (upper bainite) the ferrite laths."@en)
AnnotationAssertion(skos:definition hto:HTO_0000079 "Mikrogefüge, das aus einer Umwandlung von Austenit (3.12) resultiert bei Temperaturen über die Starttemperatur (Ms) von Martensit (3.137) und außerhalb des Bereichs von Perlit (3.155), der aus Ferritlatten und Carbiden besteht, die entweder innerhalb der Ferritlatten (untere Bainite) oder zwischen den Ferritlatten angeordnet sind (obere Bainite)."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000079 "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.17 + Tabelle 1."@en)
SubClassOf(hto:HTO_0000079 co:PMD_0000857)

# Class: hto:HTO_0000080 (Ferrit)

AnnotationAssertion(dc:source hto:HTO_0000080 "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)")
AnnotationAssertion(dc:source hto:HTO_0000080 "DIN EN ISO 4885:2018, §3.85")
AnnotationAssertion(rdfs:label hto:HTO_0000080 "Ferrit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000080 "ferrite"@en)
AnnotationAssertion(skos:definition hto:HTO_0000080 "Gefüge von Eisen oder Stahl mit kubisch-raumzentrierter Gitterstruktur."@de)
AnnotationAssertion(skos:definition hto:HTO_0000080 "Microstructure of iron or steel with a body-centred cubic lattice structure."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000080 "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.85 + Tabelle 1."@en)
SubClassOf(hto:HTO_0000080 co:PMD_0000857)

# Class: hto:HTO_0000081 (Perlit)

AnnotationAssertion(dc:source hto:HTO_0000081 "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)")
AnnotationAssertion(dc:source hto:HTO_0000081 "DIN EN ISO 4885:2018, §3.155")
AnnotationAssertion(rdfs:label hto:HTO_0000081 "Perlit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000081 "pearlite"@en)
AnnotationAssertion(skos:definition hto:HTO_0000081 "Aus Ferrit- (3.85) und Zementit- (3.39) Lamellen bestehender Gefügebestandteil, der durch die eutektoidische Austenitumwandlung (3.56) und der gleichzeitig ablaufenden Transformation in Ferrit und Zementit gebildet wird."@de)
AnnotationAssertion(skos:definition hto:HTO_0000081 "Microstructure constituent consisting of ferrite (3.85) and cementite (3.39) lamellae, formed by the eutectoidic transformation of austenite (3.56) and the concomitant transformation into ferrite and cementite."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000081 "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.155 + Tabelle 1."@en)
SubClassOf(hto:HTO_0000081 co:PMD_0000857)

# Class: hto:HTO_0000082 (cementite)

AnnotationAssertion(dc:source hto:HTO_0000082 "DIN EN ISO 4885:2018, Tabelle 1 (Fe-C-Phasen)")
AnnotationAssertion(dc:source hto:HTO_0000082 "DIN EN ISO 4885:2018, §3.39")
AnnotationAssertion(rdfs:label hto:HTO_0000082 "Zementit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000082 "cementite"@en)
AnnotationAssertion(skos:definition hto:HTO_0000082 "Microstructure composed of iron carbide with composition Fe3C."@en)
AnnotationAssertion(skos:definition hto:HTO_0000082 "Mokrogefüge, das das Carbid des Eisens, mit der Zusammensetzung Fe3C ist."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000082 "DIN audit addition (2026-06-09): Fe-C phase from DIN EN ISO 4885 §3.39 + Tabelle 1."@en)
SubClassOf(hto:HTO_0000082 co:PMD_0000857)

# Class: hto:HTO_0000083 (martensite start temperature)

AnnotationAssertion(dc:source hto:HTO_0000083 "DIN EN ISO 4885:2018, §3.213 Anm.1")
AnnotationAssertion(rdfs:label hto:HTO_0000083 "Martensit-Starttemperatur"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000083 "martensite start temperature"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000083 "M_s"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000083 "Ms"@de)
AnnotationAssertion(skos:definition hto:HTO_0000083 "Temperatur, bei der die Umwandlung von Austenit in Martensit (3.137) beim Abkühlen (3.45) beginnt."@de)
AnnotationAssertion(skos:definition hto:HTO_0000083 "Temperature at which the transformation of austenite into martensite (3.137) begins upon cooling (3.45)."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000083 "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1 (Bei Stählen können im Wesentlichen folgende Umwandlungstemperaturen unterschieden werden)."@en)
SubClassOf(hto:HTO_0000083 co:PMD_0020167)

# Class: hto:HTO_0000084 (martensite finish temperature)

AnnotationAssertion(dc:source hto:HTO_0000084 "DIN EN ISO 4885:2018, §3.213 Anm.1")
AnnotationAssertion(rdfs:label hto:HTO_0000084 "Martensit-Endtemperatur"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000084 "martensite finish temperature"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000084 "M_f"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000084 "Mf"@de)
AnnotationAssertion(skos:definition hto:HTO_0000084 "Temperatur, bei der die Umwandlung von Austenit in Martensit beim Abkühlen annähernd vollständig ist."@de)
AnnotationAssertion(skos:definition hto:HTO_0000084 "Temperature at which the transformation of austenite into martensite is approximately complete upon cooling."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000084 "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1."@en)
SubClassOf(hto:HTO_0000084 co:PMD_0020167)

# Class: hto:HTO_0000085 (A1-Temperatur)

AnnotationAssertion(dc:source hto:HTO_0000085 "DIN EN ISO 4885:2018, §3.213 Anm.1")
AnnotationAssertion(rdfs:label hto:HTO_0000085 "A1 transformation temperature"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000085 "A1-Temperatur"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000085 "A1"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000085 "A_1"@en)
AnnotationAssertion(skos:definition hto:HTO_0000085 "Equilibrium temperature defining the lower limit of austenite (3.12) existence."@en)
AnnotationAssertion(skos:definition hto:HTO_0000085 "Gleichgewichts-Temperatur, die die untere Grenze der Existenz von Austenit (3.12) festlegt."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000085 "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1."@en)
SubClassOf(hto:HTO_0000085 co:PMD_0020167)

# Class: hto:HTO_0000086 (A3 transformation temperature)

AnnotationAssertion(dc:source hto:HTO_0000086 "DIN EN ISO 4885:2018, §3.213 Anm.1")
AnnotationAssertion(rdfs:label hto:HTO_0000086 "A3 transformation temperature"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000086 "A3-Temperatur"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000086 "A3"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000086 "A_3"@en)
AnnotationAssertion(skos:definition hto:HTO_0000086 "Equilibrium temperature defining the upper limit of ferrite (3.85) existence."@en)
AnnotationAssertion(skos:definition hto:HTO_0000086 "Gleichgewichts-Temperatur, die die obere Grenze der Existenz von Ferrit (3.85) festlegt."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000086 "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1."@en)
SubClassOf(hto:HTO_0000086 co:PMD_0020167)

# Class: hto:HTO_0000087 (Am transformation temperature)

AnnotationAssertion(dc:source hto:HTO_0000087 "DIN EN ISO 4885:2018, §3.213 Anm.1")
AnnotationAssertion(rdfs:label hto:HTO_0000087 "Am transformation temperature"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000087 "Am-Temperatur"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000087 "A_m"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000087 "Acm"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000087 "Am"@en)
AnnotationAssertion(skos:definition hto:HTO_0000087 "Equilibrium temperature defining the upper limit of cementite (3.39) existence in a hypereutectoid steel (3.117)."@en)
AnnotationAssertion(skos:definition hto:HTO_0000087 "Gleichgewichts-Temperatur, die die obere Grenze der Existenz von Zementit (3.39) in einem übereutektoidischen Stahl (3.117) festlegt."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000087 "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1. 4885 names this 'Am'; the 'Acm' altLabel is the IIW/ASM-standard naming retained for industry compatibility."@en)
SubClassOf(hto:HTO_0000087 co:PMD_0020167)

# Class: hto:HTO_0000088 (surface hardening depth)

AnnotationAssertion(dc:source hto:HTO_0000088 "DIN EN ISO 4885:2018, §3.74")
AnnotationAssertion(dc:source hto:HTO_0000088 "ISO 18203:2016, §3.5 (modifiziert)")
AnnotationAssertion(rdfs:label hto:HTO_0000088 "Einhärtungstiefe nach Randschichthärten"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000088 "surface hardening depth"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000088 "Randschichthärtungstiefe"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000088 "Rht"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000088 "SHD"@en)
AnnotationAssertion(skos:definition hto:HTO_0000088 "Abstand von der Oberfläche bis zu dem Punkt, an dem die Vickers-Härte (HV) 80 % des für die Oberflächenhärte geforderten Mindestwertes für das entsprechende Werkstück beträgt."@de)
AnnotationAssertion(skos:definition hto:HTO_0000088 "Distance from the surface to the point at which the Vickers hardness (HV) equals 80% of the minimum required surface hardness for the workpiece."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000088 "DIN audit addition (2026-06-09): surface hardening depth (Rht) from DIN EN ISO 4885 §3.74 (sourced from ISO 18203:2016 §3.5 modified). Distinct from CHD (HTO_0000089) which is the depth measure for Einsatzhärten."@en)
SubClassOf(hto:HTO_0000088 co:PMD_0040001)

# Class: hto:HTO_0000089 (case hardening depth)

AnnotationAssertion(dc:source hto:HTO_0000089 "DIN EN ISO 4885:2018, §3.72")
AnnotationAssertion(dc:source hto:HTO_0000089 "ISO 18203:2016, §3.1 (modifiziert)")
AnnotationAssertion(rdfs:label hto:HTO_0000089 "Einsatzhärtungstiefe"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000089 "case hardening depth"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000089 "CHD"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000089 "Einsatzhärtungs-Härtetiefe"@de)
AnnotationAssertion(skos:definition hto:HTO_0000089 "Abstand von der Oberfläche eines Werkstückes bis zu einem die Dicke der gehärteten (3.167) Schicht festlegenden Punkt."@de)
AnnotationAssertion(skos:definition hto:HTO_0000089 "Distance from the surface of a workpiece to a point defining the thickness of the hardened (3.167) case."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000089 "DIN audit addition (2026-06-09): case hardening depth (CHD) from DIN EN ISO 4885 §3.72 (sourced from ISO 18203:2016 §3.1 modified). IMPORTANT: CHD is the depth MEASURE; do NOT confuse with hto:HTO_0000072 'case hardening' which is the PROCESS (Einsatzhärten)."@en)
SubClassOf(hto:HTO_0000089 co:PMD_0040001)

# Class: hto:HTO_0000090 (OBSOLETE Oberflächenhärtungstiefe)

AnnotationAssertion(obo:IAO_0100001 hto:HTO_0000090 hto:HTO_0000088)
AnnotationAssertion(rdfs:comment hto:HTO_0000090 "unnecessary grouping term")
AnnotationAssertion(rdfs:label hto:HTO_0000090 "OBSOLETE Oberflächenhärtungstiefe"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000090 "OBSOLETE surface hardening depth (generic)"@en)
AnnotationAssertion(owl:deprecated hto:HTO_0000090 "true"^^xsd:boolean)
AnnotationAssertion(skos:definition hto:HTO_0000090 "OBSOLETE Generic depth term for surface hardening; in industrial practice referred to as Surface Hardening Depth (SHD); in DIN normation usually narrowed to Rht (§3.74) or CHD (§3.72)."@en)
AnnotationAssertion(skos:definition hto:HTO_0000090 "OBSOLETE Generischer Tiefenbegriff für Randschichthärtungen, in der industriellen Praxis als 'Surface Hardening Depth' (SHD) verwendet; nach DIN-Normierung in der Regel präzisiert zu Rht (§3.74) oder CHD (§3.72)."@de)

# Class: hto:HTO_0000091 (hardenability)

AnnotationAssertion(dc:source hto:HTO_0000091 "DIN EN ISO 4885:2018, §3.103")
AnnotationAssertion(rdfs:label hto:HTO_0000091 "Härtbarkeit"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000091 "hardenability"@en)
AnnotationAssertion(skos:definition hto:HTO_0000091 "Relational quality describing the ability of steels to transform into martensite (3.137) and/or bainite (3.17)."@en)
AnnotationAssertion(skos:definition hto:HTO_0000091 "Relationale Eigschenschaft, die die Fähigkeit von Stählen beschreibt, zu Martensit (3.137) und/oder Bainit (3.17) umzuwandeln."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000091 "DIN audit addition (2026-06-09): material quality from DIN EN ISO 4885 §3.103. The §3.103 Anm.1 notes that Härtbarkeit is frequently quantified via the Stirnabschreckversuch (HTO_0000092)."@en)
SubClassOf(hto:HTO_0000091 obo:BFO_0000145)

# Class: hto:HTO_0000092 (Stirnabschreckversuch)

AnnotationAssertion(dc:source hto:HTO_0000092 "DIN EN ISO 4885:2018, §3.128")
AnnotationAssertion(dc:source hto:HTO_0000092 "ISO 642 (Jominy end-quench test procedure)")
AnnotationAssertion(rdfs:label hto:HTO_0000092 "Jominy end-quench test"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000092 "Stirnabschreckversuch"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000092 "Jominy test"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000092 "Jominy-Versuch"@de)
AnnotationAssertion(skos:definition hto:HTO_0000092 "Assay that is a standardised test method for assessing hardenability (3.103)."@en)
AnnotationAssertion(skos:definition hto:HTO_0000092 "Ein Assay bzw. genormtes Prüfverfahren zur Beurteilung der Härtbarkeit (3.103)."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000092 "DIN audit addition (2026-06-09): test method from DIN EN ISO 4885 §3.128. Reinforcing standards: ISO 642 (test procedure)."@en)
SubClassOf(hto:HTO_0000092 obo:OBI_0000070)
SubClassOf(hto:HTO_0000092 ObjectSomeValuesFrom(obo:RO_0009006 hto:HTO_0000091))

# Class: hto:HTO_0000093 (soft annealing)

AnnotationAssertion(dc:source hto:HTO_0000093 "DIN EN ISO 4885:2018, §3.186")
AnnotationAssertion(dc:source hto:HTO_0000093 "DIN EN ISO 683-2:2018, §7.2 (+A delivery state)")
AnnotationAssertion(rdfs:label hto:HTO_0000093 "Weichglühen"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000093 "soft annealing"@en)
AnnotationAssertion(skos:definition hto:HTO_0000093 "Heat treatment (3.108) to reduce the hardness of a ferrous product to a specified level."@en)
AnnotationAssertion(skos:definition hto:HTO_0000093 "Wärmebehandlung (3.108) zum Vermindern der Härte eines Eisenerzeugnisses auf eine vorgegebene Stufe."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000093 "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.186. Aligns with DIN EN ISO 683-2 +A delivery state (weichgeglüht)."@en)
SubClassOf(hto:HTO_0000093 hto:HTO_0000039)

# Class: hto:HTO_0000094 (normalizing)

AnnotationAssertion(dc:source hto:HTO_0000094 "DIN EN ISO 4885:2018, §3.146")
AnnotationAssertion(dc:source hto:HTO_0000094 "DIN EN ISO 683-7:2025, §6.2.1 (+N delivery state)")
AnnotationAssertion(rdfs:label hto:HTO_0000094 "Normalglühen"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000094 "normalizing"@en)
AnnotationAssertion(skos:definition hto:HTO_0000094 "Heat treatment (3.108) aimed at refining and homogenising the grain size (3.99) of a ferrous product, consisting of heating (3.109) to a temperature slightly above A3 (A1 for hypereutectoid steels (3.117)), without prolonged soaking, followed by suitable cooling (3.45) to achieve a fine ferrite-pearlite microstructure."@en)
AnnotationAssertion(skos:definition hto:HTO_0000094 "Wärmebehandlung (3.108) mit dem Ziel, die Korngröße (3.99) eines Eisenerzeugnisses zu verfeinern und schließlich einheitlicher zu machen, bestehend aus Erwärmen (3.109) auf eine Temperatur wenig oberhalb A3 (A1 bei übereutektoidischen Stählen (3.117)), ohne längeres Halten bei dieser Temperatur, und anschließendem zweckmäßigen Abkühlen (3.45) bis zum Erreichen eines feinen ferritisch-perlitischen Gefüges."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000094 "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.146. Aligns with DIN EN ISO 683-7 +N delivery state."@en)
SubClassOf(hto:HTO_0000094 hto:HTO_0000039)

# Class: hto:HTO_0000095 (stress-relief annealing)

AnnotationAssertion(dc:source hto:HTO_0000095 "DIN EN ISO 4885:2018, §3.197")
AnnotationAssertion(dc:source hto:HTO_0000095 "DIN EN ISO 683-7:2025, §6.2.1 (+SR delivery state)")
AnnotationAssertion(rdfs:label hto:HTO_0000095 "Spannungsarmglühen"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000095 "stress-relief annealing"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000095 "Spannungsarmgluehen"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000095 "stress relieving"@en)
AnnotationAssertion(skos:definition hto:HTO_0000095 "Annealing (3.8) at temperatures below A1 to reduce internal stresses without substantially altering the microstructure of a workpiece or ferrous product, followed by slow cooling (3.45)."@en)
AnnotationAssertion(skos:definition hto:HTO_0000095 "Glühen (3.8) bei Temperaturen unterhalb A1 zur Reduzierung der inneren Spannungen ohne das Gefüge eines Werkstückes oder Eisenerzeugnisses substantiell zu verändern, bis zu einer Stufe auf der die inneren Spannungen verringert werden, mit anschließendem langsamen Abkühlen (3.45)."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000095 "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.197. Aligns with DIN EN ISO 683-7 +SR delivery state."@en)
SubClassOf(hto:HTO_0000095 hto:HTO_0000039)

# Class: hto:HTO_0000096 (diffusion annealing)

AnnotationAssertion(dc:source hto:HTO_0000096 "DIN EN ISO 4885:2018, §3.64")
AnnotationAssertion(rdfs:label hto:HTO_0000096 "Diffusionsglühen"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000096 "diffusion annealing"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000096 "homogenization annealing"@en)
AnnotationAssertion(skos:definition hto:HTO_0000096 "Heat treatment (3.108) / annealing (3.8) of ferrous products or workpieces to reduce segregation (3.179) and promote homogeneity through diffusion (3.63)."@en)
AnnotationAssertion(skos:definition hto:HTO_0000096 "Wärmebehandlung (3.108)/Glühen (3.8) von Eisenerzeugnissen oder Werkstücken, um die Seigerung (3.179) zu verringern und die Homogenität durch Diffusion (3.63) zu fördern."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000096 "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.64."@en)
SubClassOf(hto:HTO_0000096 hto:HTO_0000039)

# Class: hto:HTO_0000097 (Blankglühen)

AnnotationAssertion(dc:source hto:HTO_0000097 "DIN EN ISO 4885:2018, §3.29")
AnnotationAssertion(rdfs:label hto:HTO_0000097 "Blankglühen"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000097 "bright annealing"@en)
AnnotationAssertion(skos:definition hto:HTO_0000097 "Annealing (3.8) in a medium under conditions that prevent oxidation (3.150) and preserve the original surface quality."@en)
AnnotationAssertion(skos:definition hto:HTO_0000097 "Glühen (3.8) in einem Mittel unter solchen Bedingungen, dass eine Oxidation (3.150) verhindert wird und die ursprüngliche Oberflächenqualität beibehalten wird."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000097 "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.29."@en)
SubClassOf(hto:HTO_0000097 hto:HTO_0000039)

# Class: hto:HTO_0000098 (Rekristallisationsglühen)

AnnotationAssertion(dc:source hto:HTO_0000098 "DIN EN ISO 4885:2018, §3.174")
AnnotationAssertion(rdfs:label hto:HTO_0000098 "Rekristallisationsglühen"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000098 "recrystallization annealing"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000098 "recrystallisation annealing"@en)
AnnotationAssertion(skos:definition hto:HTO_0000098 "Annealing (3.8) to eliminate the strength increase from cold deformation and to renew grains via nucleation without phase change (3.156)."@en)
AnnotationAssertion(skos:definition hto:HTO_0000098 "Glühen (3.8) zur Beseitigung der Festigkeitszunahme nach Kaltumformung und Kornneubildung durch Keimbildung ohne Änderung der Phase (3.156)."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000098 "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.174."@en)
SubClassOf(hto:HTO_0000098 hto:HTO_0000039)

# Class: hto:HTO_0000099 (zwischenkritisches Glühen)

AnnotationAssertion(dc:source hto:HTO_0000099 "DIN EN ISO 4885:2018, §3.122")
AnnotationAssertion(rdfs:label hto:HTO_0000099 "inter-critical annealing"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000099 "zwischenkritisches Glühen"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000099 "zwischenkritische Behandlung"@de)
AnnotationAssertion(skos:definition hto:HTO_0000099 "Annealing (3.8) of a hypoeutectoid steel (3.118), consisting of heating (3.109) and soaking at temperatures between A1 and A3 to partially produce austenit, followed by suitable cooling (3.45) tailored to the required properties."@en)
AnnotationAssertion(skos:definition hto:HTO_0000099 "Glühen (3.8) eines untereutektoidischen Stahls (3.118), bestehend aus Erwärmen (3.109) und Halten auf Temperaturen zwischen A1 und A3, um teilweise Austenit zu erzeugen, und anschließendem zweckentsprechenden Abkühlen (3.45), angepasst an die geforderten Eigenschaften."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000099 "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.122."@en)
SubClassOf(hto:HTO_0000099 hto:HTO_0000039)

# Class: hto:HTO_0000100 (isothermes Umwandeln)

AnnotationAssertion(dc:source hto:HTO_0000100 "DIN EN ISO 4885:2018, §3.127")
AnnotationAssertion(dc:source hto:HTO_0000100 "DIN EN ISO 4885:2018, §3.8 Anm.1")
AnnotationAssertion(rdfs:label hto:HTO_0000100 "isothermal transformation"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000100 "isothermes Umwandeln"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000100 "isothermal annealing"@en)
AnnotationAssertion(skos:definition hto:HTO_0000100 "Heat treatment (3.108) with austenitising (3.14), interrupted cooling (3.45), and isothermal hold at a specified temperature until transformation is complete."@en)
AnnotationAssertion(skos:definition hto:HTO_0000100 "Wärmebehandlung (3.108) mit Austenitisieren (3.14) und unterbrochenem Abkühlen (3.45) und Konstanthaltung auf eine bestimmte Temperatur bis zur vollständigen Umwandlung."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000100 "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.127. NB: 4885 §3.8 Anm.1 lists 'isothermes Umwandeln' as one of the named Glühen children."@en)
SubClassOf(hto:HTO_0000100 hto:HTO_0000039)

# Class: hto:HTO_0000101 (Lösungsglühen)

AnnotationAssertion(dc:source hto:HTO_0000101 "DIN EN ISO 4885:2018, §3.188")
AnnotationAssertion(rdfs:label hto:HTO_0000101 "Lösungsglühen"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000101 "solution annealing"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000101 "Lösungsbehandeln"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000101 "solution treating"@en)
AnnotationAssertion(skos:definition hto:HTO_0000101 "Heat treatment (3.108) consisting of austenitising (3.14) at a high temperature followed by sufficiently rapid cooling (3.45) to prevent new precipitation upon return to ambient temperature."@en)
AnnotationAssertion(skos:definition hto:HTO_0000101 "Wärmebehandlung (3.108), bestehend aus Austenitisieren (3.14) auf eine hohe Temperatur mit anschließendem ausreichendem schnellen Abkühlen (3.45), um neue Ausscheidungen nach der Rückkehr zur Umgebungstemperatur zu verhindern."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000101 "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.188."@en)
SubClassOf(hto:HTO_0000101 hto:HTO_0000039)

# Class: hto:HTO_0000102 (vollständiges Glühen)

AnnotationAssertion(dc:source hto:HTO_0000102 "DIN EN ISO 4885:2018, §3.8 Anm.1")
AnnotationAssertion(dc:source hto:HTO_0000102 "DIN EN ISO 4885:2018, §3.89")
AnnotationAssertion(rdfs:label hto:HTO_0000102 "full annealing"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000102 "vollständiges Glühen"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000102 "kritisches Glühen"@de)
AnnotationAssertion(skos:definition hto:HTO_0000102 "Annealing (3.8) to achieve a spheroidal microstructure (see 3.190), which involves complete austenitisation (3.14) to a temperature above A3 (for hypoeutectoid steels) or above A1 (for hypereutectoid steels), followed by slow cooling (3.45), to achieve a microstructure close to thermodynamic equilibrium."@en)
AnnotationAssertion(skos:definition hto:HTO_0000102 "Glühen (3.8) zur Erzielung von kugeligem Gefüge (siehe 3.190), was ein vollständiges Austenitisieren (3.14) auf eine Temperatur oberhalb von A3 (bei hypoeutektoiden Stählen) bzw. oberhalb von A1 (bei hypereutektoiden Stählen) beinhaltet, gefolgt von einer langsamen Abkühlung (3.45), um eine Mikrostruktur zu erzielen, die dem thermodynamischen Gleichgewicht nahekommt."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000102 "DIN audit addition (2026-06-09): Glühen-family subclass from DIN EN ISO 4885 §3.89 (Full annealing — listed inline in §3.8 Anm.1 as a named Glühen child). Definition is paraphrased per 4885 conventions; the §3.89 verbatim entry uses generic 'Wärmebehandlung'."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000102 "deviating from the standard here because 'full annealing' ist supposed to fully transform the microstructure into austenite (hence the name) whereas comparable annealing procedures do not fully transform the material even though they are within the same T-range (normalizing, intercritical annealing). Additional info and explanation provided by TWaldenmaier. (thnlrd)")
SubClassOf(hto:HTO_0000102 hto:HTO_0000039)

# Class: hto:HTO_0000103 (Austempern)

AnnotationAssertion(dc:source hto:HTO_0000103 "DIN EN ISO 4885:2018, §3.11")
AnnotationAssertion(rdfs:label hto:HTO_0000103 "Austempern"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000103 "austempering"@en)
AnnotationAssertion(skos:comment hto:HTO_0000103 "In practical use, the terms bainitising and austempering are used interchangeably cheifly in US-american english. (thnlrd)"@en)
AnnotationAssertion(skos:definition hto:HTO_0000103 "Isothermal heat treatment to produce a bainitic (cf. 3.17, 3.18) or ausferritic (cf. 3.9) microstructure in a workpiece."@en)
AnnotationAssertion(skos:definition hto:HTO_0000103 "Isotherme Wärmebehandlung zur Herstellung eines bainitischen (siehe 3.17 und 3.18) oder ausferritischen (siehe 3.9) Gefüges eines Werkstückes."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000103 "DIN audit addition (2026-06-09): isothermal-treatment process from DIN EN ISO 4885 §3.11. Closely related to Bainitisieren (HTO_0000104, §3.18)."@en)
EquivalentClasses(hto:HTO_0000103 hto:HTO_0000104)
SubClassOf(hto:HTO_0000103 co:PMD_0000779)

# Class: hto:HTO_0000104 (Bainitisieren)

AnnotationAssertion(dc:source hto:HTO_0000104 "DIN EN ISO 4885:2018, §3.18")
AnnotationAssertion(rdfs:label hto:HTO_0000104 "Bainitisieren"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000104 "bainitising"@en)
AnnotationAssertion(skos:comment hto:HTO_0000104 "In practical use, the terms bainitising and austempering are used interchangeably cheifly in US-american english. (thnlrd)"@en)
AnnotationAssertion(skos:definition hto:HTO_0000104 "Austenitisieren (3.14) und Abschrecken (3.168) auf eine Temperatur oberhalb Ms und isothermes Halten auf dieser Temperatur, um sicherzustellen, dass sich der Austenit (3.12) in Bainit (3.17) umwandelt."@de)
AnnotationAssertion(skos:definition hto:HTO_0000104 "Austenitising (3.14) and quenching (3.168) to a temperature above Ms followed by isothermal hold at that temperature so that austenite (3.12) transforms into bainite (3.17)."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000104 "DIN audit addition (2026-06-09): process from DIN EN ISO 4885 §3.18."@en)
SubClassOf(hto:HTO_0000104 co:PMD_0000779)

# Class: hto:HTO_0000105 (patenting)

AnnotationAssertion(dc:source hto:HTO_0000105 "DIN EN ISO 4885:2018, §3.154")
AnnotationAssertion(rdfs:label hto:HTO_0000105 "Patentieren"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000105 "patenting"@en)
AnnotationAssertion(skos:definition hto:HTO_0000105 "Heat treatment (3.108) consisting of austenitising (3.14) followed by suitable cooling (3.45) to produce a microstructure favourable for subsequent drawing or roll-drawing of wire or strip."@en)
AnnotationAssertion(skos:definition hto:HTO_0000105 "Wärmebehandlung (3.108), bestehend aus Austenitisieren (3.14) und anschließendem geeigneten Abkühlen (3.45), um ein für das nachfolgende Ziehen oder Ziehwalzen von Draht oder Band günstiges Gefüge zu erreichen."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000105 "DIN audit addition (2026-06-09): process from DIN EN ISO 4885 §3.154."@en)
SubClassOf(hto:HTO_0000105 co:PMD_0000779)

# Class: hto:HTO_0000107 (single hardening)

AnnotationAssertion(dc:source hto:HTO_0000107 "DIN EN ISO 4885:2018, §3.184")
AnnotationAssertion(rdfs:label hto:HTO_0000107 "Einfachhärten"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000107 "single hardening"@en)
AnnotationAssertion(skos:definition hto:HTO_0000107 "In einem Schritt durchgeführtes Härten nach vorausgegangenem Aufkohlen (3.36) und langsamem Abkühlen (3.45) auf Raumtemperatur."@de)
AnnotationAssertion(skos:definition hto:HTO_0000107 "Single-step hardening following prior carburising (3.36) and slow cooling (3.45) to room temperature."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000107 "DIN audit addition (2026-06-09): hardening sub-process from DIN EN ISO 4885 §3.184 (siehe Bild 1 b)."@en)
SubClassOf(hto:HTO_0000107 hto:HTO_0000040)

# Class: hto:HTO_0000108 (Mx-Temperatur)

AnnotationAssertion(dc:source hto:HTO_0000108 "DIN EN ISO 4885:2018, §3.213 Anm.1")
AnnotationAssertion(rdfs:label hto:HTO_0000108 "Mx transformation temperature"@en)
AnnotationAssertion(rdfs:label hto:HTO_0000108 "Mx-Temperatur"@de)
AnnotationAssertion(skos:altLabel hto:HTO_0000108 "M_x"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000108 "Mx"@en)
AnnotationAssertion(skos:definition hto:HTO_0000108 "Temperatur, bei der beim Abkühlen x % Volumenanteil Austenit in Martensit umgewandelt wurden."@de)
AnnotationAssertion(skos:definition hto:HTO_0000108 "Temperature at which, upon cooling, x % volume fraction of austenite has transformed into martensite."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000108 "DIN audit addition (2026-06-09): transition temperature from DIN EN ISO 4885 §3.213 Anm.1 (parametric x ∈ (0,100))."@en)
SubClassOf(hto:HTO_0000108 co:PMD_0020167)

# Class: hto:HTO_0000109 (chamber)

AnnotationAssertion(obo:IAO_0000114 hto:HTO_0000109 "needs work")
AnnotationAssertion(dc:source hto:HTO_0000109 "DIN 17022-1:1994, §7 (generic multi-chamber furnace construction)")
AnnotationAssertion(rdfs:comment hto:HTO_0000109 "unklare Zuordnung innerhalb der SDCs. Eine Kammer existiert nur als Teil eines Gerätes (Device), könnte aber selbst noch einmal als independent continuant definiert werden, da sich in der Kammer Chargen, Gestelle, Thermoelemente etc. befinden."@de)
AnnotationAssertion(rdfs:comment hto:HTO_0000109 "moved to fiat object part. correct if every furnace has a chamber")
AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000109 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000109 "chamber"@en)
AnnotationAssertion(skos:definition hto:HTO_0000109 "Systemboundary of a distinct Heattreatment Process. Includes a fluid that has the role of medium role (e.g., Helium or Vacuum)."@en)
SubClassOf(hto:HTO_0000109 obo:BFO_0000024)

# Class: hto:HTO_0000110 (heating chamber)

AnnotationAssertion(dc:source hto:HTO_0000110 "DIN 17022-1:1994, §7 (Ofen-Konstruktion)")
AnnotationAssertion(dc:source hto:HTO_0000110 "DIN 17022-4:1998, §10")
AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000110 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000110 "Heizkammer"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000110 "heating chamber"@en)
AnnotationAssertion(skos:definition hto:HTO_0000110 "Distinguishable chamber of a heat treatment furnace with a heater."@en)
AnnotationAssertion(skos:definition hto:HTO_0000110 "Ofenkammer mit einer Heizung"@de)
SubClassOf(hto:HTO_0000110 hto:HTO_0000109)

# Class: hto:HTO_0000111 (quenching chamber)

AnnotationAssertion(dc:source hto:HTO_0000111 "DIN 17022-1:1994, §7.2 (Abschreckeinrichtung)")
AnnotationAssertion(dc:source hto:HTO_0000111 "DIN 17022-4:1998, §10.3 (Fassungsverhältnis ≥ 6× Chargengewicht)")
AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000111 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000111 "Abschreckkammer"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000111 "quenching chamber"@en)
AnnotationAssertion(skos:definition hto:HTO_0000111 "Chamber of a heat treatment furnace that is designed to quench objects."@en)
AnnotationAssertion(skos:definition hto:HTO_0000111 "Kammer eines Wärmebehandlungsofens, die zum Abschrecken von Gegenständen bestimmt ist."@de)
SubClassOf(hto:HTO_0000111 hto:HTO_0000109)

# Class: hto:HTO_0000112 (Kohlenstoffpotential)

AnnotationAssertion(dc:source hto:HTO_0000112 "DIN EN ISO 4885:2018, §3.33 (Kohlenstoffpegel — contrast Anm.1)")
AnnotationAssertion(dc:source hto:HTO_0000112 "DIN EN ISO 683-3:2022, §A.4 (carburising atmosphere control)")
AnnotationAssertion(rdfs:comment hto:HTO_0000112 "Nitrocarburieren mit Kohlenstoffträger, aus Messwerten abgeleitet KC"@de)
AnnotationAssertion(rdfs:comment hto:HTO_0000112 "See standard DIN 1310"@en)
AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000112 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000112 "Kohlenstoffpotential"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000112 "carbon potential"@en)
AnnotationAssertion(skos:definition hto:HTO_0000112 "Carbon content of a specimen of pure iron in equilibrium with a carbourizing medium under specific conditions."@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000112 "DIN audit (2026-06-09): DIN EN ISO 4885 §3.33 names the operational quantity 'Kohlenstoffpegel' (carbon level), with §3.33 Anm.1 contrasting it explicitly with the 'thermodynamisches Kohlenstoffpotenzial'. 4885 treats the two as NOT synonymous. hto:CarbonPotential is retained as the thermodynamic-potential quality; the new sibling hto:HTO_0000076 (CarbonLevel) carries the §3.33 operational definition. See hto:HTO_0000076 below for the sibling class."@en)
SubClassOf(hto:HTO_0000112 obo:BFO_0000145)

# Class: hto:HTO_0000113 (Nitrierkennzahl)

AnnotationAssertion(dc:source hto:HTO_0000113 "DIN 17022-4:1998, §7.3 eq.3 (K_N = p_{NH3} / p_{H2}^{1.5})")
AnnotationAssertion(rdfs:comment hto:HTO_0000113 "The nitriding potential is a key indicator how intensive the nitriding process is, the higher the value the stronger the nitriding conditions, unit is bar^-3/2"@en)
AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000113 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000113 "Nitrierkennzahl"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000113 "nitrogen potential"@en)
AnnotationAssertion(skos:definition hto:HTO_0000113 "A relational quality describing the intensity of a nitriding atmosphere by relating the partial pressures of ammonia and hydrogen gas."@en)
SubClassOf(hto:HTO_0000113 obo:BFO_0000145)

# Class: hto:HTO_0000114 (Partialdruck)

AnnotationAssertion(dc:source hto:HTO_0000114 "DIN 17022-4:1998, §7.3 eq.3 (p_NH3, p_H2 in K_N formula)")
AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000114 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000114 "Partialdruck"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000114 "partial pressure"@en)
AnnotationAssertion(skos:definition hto:HTO_0000114 "Realtional quality describing the contribution from a single gas species to the total pressure in a gas mixture."@en)
AnnotationAssertion(skos:definition hto:HTO_0000114 "Relationale Eigenschaft die den Beitrag eines Gases zum Gesamtdruck in einem Gasgemisch beschreibt."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000114 "DIN audit (2026-06-09): DIN EN ISO 4885 has no §3 entry for partial pressure; this is upstream physical-chemistry vocabulary, not DIN-terminology-native. Operational usage in DIN 17022-4 §7.3 (p_NH3, p_H2 in K_N formula) is the only DIN anchor."@en)
SubClassOf(hto:HTO_0000114 obo:BFO_0000145)

# Class: hto:HTO_0000116 (chamber pressure)

AnnotationAssertion(dc:source hto:HTO_0000116 "DIN 17022-1:1994, §7 (chamber/Ofen-Konstruktion)")
AnnotationAssertion(dc:source hto:HTO_0000116 "DIN 17022-4:1998, §7.3")
AnnotationAssertion(dc:source hto:HTO_0000116 "DIN 17022-4:1998, §7.3 (Ofendruck)")
AnnotationAssertion(dc:source hto:HTO_0000116 "DIN EN ISO 4885:2018, §3.165 (Ofenatmosphäre, related quality)")
AnnotationAssertion(rdfs:comment hto:HTO_0000116 "Effective atmosphere pressure in chamber to keep process save must be 2-3 mbar above ambient pressure."@en)
AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000116 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000116 "chamber pressure"@en)
AnnotationAssertion(skos:altLabel hto:HTO_0000116 "atmosphere pressure"@en)
AnnotationAssertion(skos:definition hto:HTO_0000116 "A pressure which inheres within the confines (atmosphere) of an oven chamber."@en)
EquivalentClasses(hto:HTO_0000116 ObjectIntersectionOf(co:PMD_0000896 ObjectSomeValuesFrom(obo:RO_0000080 hto:HTO_0000109)))

# Class: hto:HTO_0000117 (rotation speed specification)

