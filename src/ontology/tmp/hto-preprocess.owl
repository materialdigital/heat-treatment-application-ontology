AnnotationAssertion(rdfs:label hto:HTO_0000062 "Abschrecken"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000062 "quenching"@en)
AnnotationAssertion(skos:definition hto:HTO_0000062 "Grundsätzlicher Wärmebehandlungsvorgang mit stark erhöhter Abkühlgeschwindigkeit, mit dem Ziel der Verhinderung diffusionsgesteuerter Umwandlungen."@de)
AnnotationAssertion(skos:definition hto:HTO_0000062 "Grundsätzlicher Wärmebehandlungsvorgang, bei dem ein Werkstück mit größerer Geschwindigkeit als an ruhender Luft abgekühlt (3.45) wird."@de)
AnnotationAssertion(skos:definition hto:HTO_0000062 "essential heat treatment process in which a workpiece is cooled (3.45) at a higher rate than in still air."@en)
AnnotationAssertion(skos:definition hto:HTO_0000062 "essential heat treatment process with significantly increased cooling rate, aimed at preventing diffusion based transformations."@en)
SubClassOf(hto:HTO_0000062 co:PMD_0025011)

