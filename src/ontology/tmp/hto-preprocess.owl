# Class: hto:HTO_0000032 (Sollwert)

AnnotationAssertion(dc:source hto:HTO_0000032 "DIN 17022-1:1994, §5 (Sollwert / Solltemperatur, procedural usage)")
AnnotationAssertion(dcterms:creator hto:HTO_0000032 "thonagel")
AnnotationAssertion(rdfs:comment hto:HTO_0000032 "Internally (within the devices' logic) a process is run to reach and maintain the given setpoint.")
AnnotationAssertion(rdfs:label hto:HTO_0000032 "Sollwert"@de)
AnnotationAssertion(rdfs:label hto:HTO_0000032 "setpoint"@en)
AnnotationAssertion(skos:definition hto:HTO_0000032 "A Set Point is a specification datum that assigns a desired quantitative value to a controlled process parameter, serving as the normative reference for process execution and control."@en)
AnnotationAssertion(skos:definition hto:HTO_0000032 "Ein Sollwert ist ein Spezifikationswert, der einem geregelten Prozessparameter einen gewünschten quantitativen Wert zuweist und als normgebende Referenz für die Prozessausführung und -steuerung dient."@de)
AnnotationAssertion(skos:editorialNote hto:HTO_0000032 "DIN audit (2026-06-09): DIN EN ISO 4885 does not enumerate 'Sollwert' as a §3 lemma; PMDco owns the generic 'setpoint' concept upstream. The DIN procedural anchor is DIN 17022-1 §5 (Sollwert / Solltemperatur operational usage). Provenance is therefore procedural rather than terminological."@en)
AnnotationAssertion(skos:example hto:HTO_0000032 "The flow rate for a mass flow controller.
The target temperature in the furnace chamber for a given process step.
The rotational speed of a fan.")
AnnotationAssertion(co:PMD_0000064 hto:HTO_0000032 "tdb")
SubClassOf(hto:HTO_0000032 co:PMD_0060009)

# Class: hto:HTO_0000033 (device operation state)

AnnotationAssertion(dcterms:creator hto:HTO_0000033 "thonagel")
AnnotationAssertion(rdfs:label hto:HTO_0000033 "device operation state"@en)
AnnotationAssertion(skos:definition hto:HTO_0000033 "A Device Operation State is a state that inheres in a device and specifies whether a device function is currently active or inactive, typically represented in a control or output protocol as an on/off (or analogous binary) indicator."@en)
AnnotationAssertion(skos:definition hto:HTO_0000033 "Switches are device specifications that triggers a certain function within a device that can only assume two states (on/off)."@en)
SubClassOf(hto:HTO_0000033 co:PMD_0060006)
SubClassOf(hto:HTO_0000033 ObjectSomeValuesFrom(obo:BFO_0000051 hto:HTO_0000034))
SubClassOf(hto:HTO_0000033 ObjectSomeValuesFrom(obo:IAO_0000136 co:PMD_0000602))

