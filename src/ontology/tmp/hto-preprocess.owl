AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000117 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000117 "rotation speed specification"@en)
AnnotationAssertion(skos:definition hto:HTO_0000117 "A setpoint describing the intended rotational speed of a device e.g. an fan or turbine."@en)
