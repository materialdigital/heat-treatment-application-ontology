# Class: hto:HTO_0000118 (dew point)

AnnotationAssertion(Annotation(skos:editorialNote "the source given (DIN EN ISO 683-3) does not contain info about dew points (thoni)") dc:source hto:HTO_0000118 "DIN EN ISO 683-3:2022, §A.4 Anm. (Taupunkt as carburising atmosphere control variable)")
AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000118 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000118 "dew point"@en)
AnnotationAssertion(skos:definition hto:HTO_0000118 "dew point of the atmosphere, measured during process or calculated from lambda / oxygen probe signal "@en)
SubClassOf(hto:HTO_0000118 obo:IAO_0000109)

# Class: hto:HTO_0000119 (hydrogene sensor signal)

AnnotationAssertion(dc:source hto:HTO_0000119 "DIN 17022-4:1998, §7.3 (H2 atmosphere monitoring, p_H2 in K_N formula)")
AnnotationAssertion(rdfs:comment hto:HTO_0000119 "nominal pre-set value of control system for hydrogen probe "@en)
AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000119 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000119 "hydrogene sensor signal"@en)
AnnotationAssertion(skos:definition hto:HTO_0000119 "measured hydrogen value of  hydrogen probe measured in milli volt "@en)
SubClassOf(hto:HTO_0000119 obo:IAO_0000109)

# Class: hto:HTO_0000120 (lambda probe signal)

AnnotationAssertion(Annotation(skos:editorialNote "the source given (DIN EN ISO 683-3) does not contain info about lambda probes or oxygen (thnlrd)") dc:source hto:HTO_0000120 "DIN EN ISO 683-3:2022, §A.4 Anm. (atmosphere-control umbrella; lambda probe is industry-vendor term for the O2 probe class)")
AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000120 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000120 "lambda probe signal"@en)
AnnotationAssertion(skos:definition hto:HTO_0000120 "measured lambda probe signal in exhaust gas "@en)
AnnotationAssertion(skos:editorialNote hto:HTO_0000120 "DIN audit (2026-06-09): 'Lambdasonde' is not explicitly named in DIN 683-3 §A.4 (it uses the generic 'Sauerstoffsonde'); the lambda probe is a specific O2-probe variant used for burner stoichiometry in fuel-fired furnaces. Provenance is operational / inferred, not direct."@en)
SubClassOf(hto:HTO_0000120 obo:IAO_0000109)

# Class: hto:HTO_0000121 (oxygen probe signal)

AnnotationAssertion(Annotation(skos:editorialNote "the source given (DIN EN ISO 683-3) does not contain info about oxygen probes (thnlrd)") dc:source hto:HTO_0000121 "DIN EN ISO 683-3:2022, §A.4 Anm. (Sauerstoffsonde / O2 probe for Cp atmosphere control)")
AnnotationAssertion(rdfs:isDefinedBy hto:HTO_0000121 <https://w3id.org/pmd/hto/>)
AnnotationAssertion(rdfs:label hto:HTO_0000121 "oxygen probe signal"@en)
AnnotationAssertion(skos:definition hto:HTO_0000121 "A measurement datum generated by an electrochemical or optical sensor, representing the specific concentration of elemental oxygen within a sampled medium."@en)
SubClassOf(hto:HTO_0000121 obo:IAO_0000109)


