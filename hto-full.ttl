               co:PMD_0000060 "true"^^xsd:boolean .


###  https://w3id.org/pmd/co/PMD_0000512
co:PMD_0000512 rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Restriction ;
                                     owl:onProperty co:PMD_0000077 ;
