co:PMD_0000654 rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( co:PMD_0000000
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty obo:BFO_0000050 ;
