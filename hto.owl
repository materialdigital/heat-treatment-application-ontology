     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:csvw="http://www.w3.org/ns/csvw#"
     xmlns:doap="http://usefulinc.com/ns/doap#"
     xmlns:nfdi="https://nfdi.fiz-karlsruhe.de/ontology/"
     xmlns:pmde="https://w3id.org/pmd/entity/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:unit="http://qudt.org/vocab/unit/"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="https://w3id.org/pmd/hto/">
        <owl:versionIRI rdf:resource="https://w3id.org/pmd/hto/3.0.0"/>
        <dcterms:bibliographicCitation>PMD Heat Treatment Ontology. Version 3.0.0, https://w3id.org/pmd/hto/</dcterms:bibliographicCitation>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-1649-6832"/>
        <dcterms:created>2026-07-10</dcterms:created>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0002-9014-2920"/>
        <dcterms:creator rdf:resource="https://orcid.org/0009-0004-4787-4685"/>
        <dcterms:creator>Divya Gosula</dcterms:creator>
        <dcterms:description xml:lang="en">This ontology module is part of the Platform Material Digital Application Ontology (PMDao) and covers concepts related to heat treatment processes, parameters, and materials. It is designed to facilitate data integration, sharing, and analysis in the field of materials science and engineering, particularly focusing on heat treatment applications.</dcterms:description>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <dcterms:title xml:lang="en">Platform Material Digital Application Ontology (PMDao) - Heat Treatment Module</dcterms:title>
        <doap:repository rdf:resource="https://github.com/materialdigital/heat-treatment-application-ontology"/>
        <owl:versionInfo>3.0.0</owl:versionInfo>
    </owl:Ontology>
    


